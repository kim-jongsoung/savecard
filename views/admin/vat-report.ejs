                    <label class="form-label fw-bold small">발급일 <span class="text-danger">*</span></label>
                    <input type="date" class="form-control" id="rv-date">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold small">업체명 (공급자) <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="rv-supplier" placeholder="예: 신한카드">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold small">세금계산서 발행금액</label>
