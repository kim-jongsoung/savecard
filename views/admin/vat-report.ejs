<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
const fmt  = n => Math.round(n||0).toLocaleString('ko-KR');
const fmtW = n => '₩' + fmt(n);

let currentYear  = new Date().getFullYear();
let currentMonth = new Date().getMonth() + 1;
let reportData   = null;

// ==================== 초기화 ====================
document.addEventListener('DOMContentLoaded', () => {
    // 연도 셀렉트
    const sel = document.getElementById('selYear');
    for (let y = currentYear + 1; y >= 2024; y--) {
        const o = document.createElement('option');
        o.value = y; o.textContent = y + '년';
        if (y === currentYear) o.selected = true;
        sel.appendChild(o);
    }
    sel.addEventListener('change', () => { currentYear = parseInt(sel.value); renderMonthBtns(); loadYearlyList(); });

    renderMonthBtns();
    loadYearlyList();
    selectMonth(currentMonth);
});

function renderMonthBtns() {
    const wrap = document.getElementById('monthBtns');
    wrap.innerHTML = '';
    const halfLabel = ['1~6월 (1기)', '7~12월 (2기)'];
    [0,1].forEach(h => {
        const div = document.createElement('div');
        div.className = 'd-flex flex-column align-items-center me-3';
        div.innerHTML = `<small class="text-muted fw-bold mb-1">${halfLabel[h]}</small><div class="d-flex gap-1" id="halfBtns${h}"></div>`;
        wrap.appendChild(div);
        for (let m = h*6+1; m <= h*6+6; m++) {
            const btn = document.createElement('button');
            btn.className = 'month-btn' + (m === currentMonth ? ' active' : '');
            btn.textContent = m + '월';
            btn.dataset.month = m;
            btn.onclick = () => selectMonth(m);
            document.getElementById('halfBtns'+h).appendChild(btn);
        }
    });
    document.getElementById('halfBadge').textContent = currentMonth <= 6 ? '1기 (1~6월)' : '2기 (7~12월)';
}

async function selectMonth(m) {
    currentMonth = m;
    document.querySelectorAll('.month-btn').forEach(b => b.classList.toggle('active', parseInt(b.dataset.month) === m));
    document.getElementById('halfBadge').textContent = m <= 6 ? '1기 (1~6월)' : '2기 (7~12월)';
    await loadReport();
}

// ==================== 리포트 로드 ====================
async function loadReport() {
    try {
        const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}`);
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        reportData = data.data;
        renderReport(reportData);
        document.getElementById('summaryRow').style.display = '';
        document.getElementById('mainContent').style.display = '';
    } catch(e) {
        alert('리포트 로드 실패: ' + e.message);
    }
}

function renderReport(r) {
    document.getElementById('inputSalesBase').value = r.sales_base || 0;
    document.getElementById('inputSalesTax').value  = r.sales_tax  || 0;
    document.getElementById('reportNotes').value    = r.notes || '';

    // 요약 카드
    document.getElementById('sSalesBase').textContent   = fmtW(r.sales_base);
    document.getElementById('sSalesTax').textContent    = fmtW(r.sales_tax);
    document.getElementById('sPurchaseTax').textContent = fmtW(r.total_purchase_tax);
    document.getElementById('sReverseTax').textContent  = fmtW(r.reverse_tax_total);
    document.getElementById('sReverseCount').textContent = (r.reverse_invoices||[]).length + '건';

    const payable = r.tax_payable || 0;
    const payEl = document.getElementById('sTaxPayable');
    payEl.textContent = (payable >= 0 ? '납부 ' : '환급 ') + fmtW(Math.abs(payable));
    payEl.className = 'stat-value ' + (payable >= 0 ? 'c-red' : 'c-green');
    document.getElementById('sTaxNote').textContent = payable >= 0 ? '세무서에 납부' : '환급 신청 가능';

    // 상태 배지
    const statusMap = { draft:'badge-draft', confirmed:'badge-confirmed', filed:'badge-filed' };
    const statusLabel = { draft:'작성중', confirmed:'확정', filed:'신고완료' };
    document.getElementById('statusBadgeTop').innerHTML = `<span class="${statusMap[r.status]||'badge-draft'}">${statusLabel[r.status]||'작성중'}</span>`;

    // 계좌 매입 테이블
    renderBankTable(r.bank_purchase_items || []);
    // 카드 테이블
    renderCardTable(r.card_expenses || []);
    // 역발급 테이블
    renderReverseTable(r.reverse_invoices || []);
    // 신고요약
    renderSummaryTab(r);
}

function renderBankTable(items) {
    const tbody = document.getElementById('bankTable');
    if (!items.length) { tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">해당 월 계좌 출금 내역이 없습니다</td></tr>'; return; }
    tbody.innerHTML = items.map(i => `
        <tr>
            <td>${i.label || i.category}</td>
            <td class="text-end">${i.count}건</td>
            <td class="text-end">${fmtW(i.total_amount)}</td>
            <td class="text-center">${i.deductible ? '<span class="deductible-yes"><i class="fas fa-check-circle"></i> 공제</span>' : '<span class="deductible-no"><i class="fas fa-minus-circle"></i> 불가</span>'}</td>
            <td class="text-end ${i.deductible ? 'c-green fw-bold' : 'text-muted'}">${i.deductible ? fmtW(i.tax_amount) : '-'}</td>
        </tr>`).join('');

    const deductItems = items.filter(i => i.deductible);
    document.getElementById('bankTotalAmount').textContent = fmtW(deductItems.reduce((s,i)=>s+i.total_amount,0));
    document.getElementById('bankTotalTax').textContent    = fmtW(deductItems.reduce((s,i)=>s+i.tax_amount,0));
}

function renderCardTable(items) {
    const tbody = document.getElementById('cardTable');
    document.getElementById('cardCount').textContent = items.length;
    const deductTotal = items.filter(c=>c.deductible).reduce((s,c)=>s+(c.tax_amount||0),0);
    document.getElementById('cardDeductibleTotal').textContent = fmtW(deductTotal);

    if (!items.length) { tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-muted">카드 내역을 업로드해주세요</td></tr>'; return; }
    tbody.innerHTML = items.map(c => {
        const dt = c.date ? new Date(c.date).toLocaleDateString('ko-KR',{month:'2-digit',day:'2-digit'}) : '-';
        return `<tr>
            <td style="white-space:nowrap">${dt}</td>
            <td>${c.merchant || '-'}</td>
            <td class="text-end">${fmtW(c.amount)}</td>
            <td class="text-end">${fmtW(c.supply_amount)}</td>
            <td class="text-end ${c.deductible?'c-green fw-bold':'text-muted'}">${fmtW(c.tax_amount)}</td>
            <td class="text-center">
                <div class="form-check form-switch d-flex justify-content-center mb-0">
                    <input class="form-check-input" type="checkbox" ${c.deductible?'checked':''} onchange="toggleCardDeductible('${c._id}',this.checked)" style="cursor:pointer">
                </div>
            </td>
            <td><input type="text" class="form-control form-control-sm" value="${c.notes||''}" placeholder="메모" onchange="updateCardNote('${c._id}',this.value)" style="min-width:80px"></td>
        </tr>`;
    }).join('');
}

function renderReverseTable(items) {
    const tbody = document.getElementById('reverseTable');
    if (!items.length) { tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-muted">등록된 역발급 계산서가 없습니다</td></tr>'; return; }
    tbody.innerHTML = items.map(i => {
        const dt = i.date ? new Date(i.date).toLocaleDateString('ko-KR') : '-';
        return `<tr>
            <td style="white-space:nowrap">${dt}</td>
            <td class="fw-bold">${i.supplier_name}</td>
            <td class="text-end">${fmtW(i.total_amount)}</td>
            <td class="text-end">${fmtW(i.supply_amount)}</td>
            <td class="text-end c-orange fw-bold">${fmtW(i.tax_amount)}</td>
            <td>${i.notes||''}</td>
            <td class="text-center"><button class="btn btn-outline-danger btn-sm py-0 px-2" onclick="deleteReverseInvoice('${i._id}')"><i class="fas fa-trash"></i></button></td>
        </tr>`;
    }).join('');
    document.getElementById('reverseTotalSupply').textContent = fmtW(items.reduce((s,i)=>s+(i.supply_amount||0),0));
    document.getElementById('reverseTotalTax').textContent    = fmtW(items.reduce((s,i)=>s+(i.tax_amount||0),0));
}

function renderSummaryTab(r) {
    document.getElementById('sum-salesBase').textContent        = fmtW(r.sales_base);
    document.getElementById('sum-salesTax').textContent         = fmtW(r.sales_tax);
    document.getElementById('sum-bankTax').textContent          = fmtW(r.bank_deductible_tax);
    document.getElementById('sum-cardTax').textContent          = fmtW(r.card_deductible_tax);
    document.getElementById('sum-reverseTax').textContent       = fmtW(r.reverse_tax_total);
    document.getElementById('sum-totalPurchaseTax').textContent = fmtW(r.total_purchase_tax);
    const payable = r.tax_payable || 0;
    const el = document.getElementById('sum-taxPayable');
    el.textContent = (payable >= 0 ? '납부 ' : '환급 ') + fmtW(Math.abs(payable));
    el.className   = 'text-end ' + (payable >= 0 ? 'c-red' : 'c-green');
    // 월 레이블 업데이트
    document.getElementById('curMonthLabel').textContent = currentMonth + '월';
}

// ==================== 연간 목록 ====================
let yearlyCache = []; // 연간 데이터 캐시

async function loadYearlyList() {
    try {
        const res  = await fetch(`/api/vat-report/list/${currentYear}`);
        const data = await res.json();
        if (!data.success) return;
        yearlyCache = data.data;
        renderYearlyTable(yearlyCache);
    } catch(e) { console.error(e); }
}

function renderYearlyTable(list) {
    const tbody   = document.getElementById('yearlyTable');
    const statusLabel = { draft:'작성중', confirmed:'확정', filed:'신고완료' };
    const statusClass = { draft:'badge-draft', confirmed:'badge-confirmed', filed:'badge-filed' };
    document.getElementById('yearlyTableYear').textContent = currentYear;

    if (!list.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center py-3 text-muted">저장된 신고 없음</td></tr>';
        ['yearlyTotalBase','yearlyTotalSalesTax','yearlyTotalPayable'].forEach(id => document.getElementById(id).textContent = '-');
        ['h1SalesTax','h1Payable','h2SalesTax','h2Payable'].forEach(id => document.getElementById(id).textContent = '-');
        return;
    }

    tbody.innerHTML = list.map(r => {
        const payable = r.tax_payable || 0;
        const rowStyle = r.month === currentMonth ? 'background:#f0f0ff;font-weight:700' : '';
        return `<tr style="cursor:pointer;${rowStyle}" onclick="selectMonth(${r.month})">
            <td>${r.month}월</td>
            <td class="text-end">${fmtW(r.sales_base)}</td>
            <td class="text-end c-blue">${fmtW(r.sales_tax)}</td>
            <td class="text-end ${payable>=0?'c-red':'c-green'}">${payable>=0?'납부 ':'환급 '}${fmtW(Math.abs(payable))}</td>
            <td><span class="${statusClass[r.status]||'badge-draft'}">${statusLabel[r.status]||'작성중'}</span></td>
        </tr>`;
    }).join('');

    // 연간 합계
    document.getElementById('yearlyTotalBase').textContent     = fmtW(list.reduce((s,r)=>s+(r.sales_base||0),0));
    document.getElementById('yearlyTotalSalesTax').textContent = fmtW(list.reduce((s,r)=>s+(r.sales_tax||0),0));
    const totalPayable = list.reduce((s,r)=>s+(r.tax_payable||0),0);
    const tpEl = document.getElementById('yearlyTotalPayable');
    tpEl.textContent = (totalPayable>=0?'납부 ':'환급 ') + fmtW(Math.abs(totalPayable));
    tpEl.className   = 'text-end ' + (totalPayable>=0?'c-red':'c-green');

    // 반기별 소계
    const h1 = list.filter(r=>r.month<=6);
    const h2 = list.filter(r=>r.month>=7);
    const h1PayableSum = h1.reduce((s,r)=>s+(r.tax_payable||0),0);
    const h2PayableSum = h2.reduce((s,r)=>s+(r.tax_payable||0),0);
    document.getElementById('h1SalesTax').textContent = fmtW(h1.reduce((s,r)=>s+(r.sales_tax||0),0));
    document.getElementById('h2SalesTax').textContent = fmtW(h2.reduce((s,r)=>s+(r.sales_tax||0),0));
    const h1pEl = document.getElementById('h1Payable');
    h1pEl.textContent = (h1PayableSum>=0?'납부 ':'환급 ') + fmtW(Math.abs(h1PayableSum));
    h1pEl.className   = h1PayableSum>=0?'c-red':'c-green';
    const h2pEl = document.getElementById('h2Payable');
    h2pEl.textContent = (h2PayableSum>=0?'납부 ':'환급 ') + fmtW(Math.abs(h2PayableSum));
    h2pEl.className   = h2PayableSum>=0?'c-red':'c-green';
}

// ==================== 탭 전환 ====================
function switchTab(tab, btn) {
    document.querySelectorAll('.tab-content-area').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.tab-pill').forEach(b => {
        // summaryModeBtns 안의 버튼은 건드리지 않음
        if (!b.closest('#summaryModeBtns')) b.classList.remove('active');
    });
    document.getElementById('tab-' + tab).style.display = '';
    btn.classList.add('active');
    // 신고요약 탭 진입 시 월 레이블 갱신
    if (tab === 'summary') {
        document.getElementById('curMonthLabel').textContent = currentMonth + '월';
    }
}

// ==================== 신고요약 기간 모드 전환 ====================
const PERIOD_MONTHS = {
    month: null,          // 현재 선택 월
    q1:  [1,2,3],         // 1기 예정 (1~3월)
    h1:  [1,2,3,4,5,6],   // 1기 확정 (1~6월)
    q3:  [7,8,9],         // 2기 예정 (7~9월)
    h2:  [7,8,9,10,11,12],// 2기 확정 (7~12월)
};
const PERIOD_LABELS = {
    month: '',
    q1:  `${currentYear}년 1기 예정신고 (1~3월)`,
    h1:  `${currentYear}년 1기 확정신고 (1~6월)`,
    q3:  `${currentYear}년 2기 예정신고 (7~9월)`,
    h2:  `${currentYear}년 2기 확정신고 (7~12월)`,
};
let currentSummaryMode = 'month';

function switchSummaryMode(mode, btn) {
    currentSummaryMode = mode;
    document.querySelectorAll('#summaryModeBtns .tab-pill').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const isMonth = (mode === 'month');
    document.getElementById('periodWarning').style.display      = isMonth ? 'none' : '';
    document.getElementById('periodMonthBreakdown').style.display = isMonth ? 'none' : '';
    document.getElementById('monthModeActions').style.display   = isMonth ? '' : 'none';
    document.getElementById('periodModeActions').style.display  = isMonth ? 'none' : '';

    const labelMap = {
        month: currentMonth + '월',
        q1:  '1기 예정 (1~3월)',
        h1:  '1기 확정 (1~6월)',
        q3:  '2기 예정 (7~9월)',
        h2:  '2기 확정 (7~12월)',
    };
    document.getElementById('periodLabel').textContent       = isMonth ? '' : `${currentYear}년 ${labelMap[mode]}`;
    document.getElementById('periodBadgeInCard').textContent = isMonth ? '' : labelMap[mode];
    document.getElementById('periodWarningText').textContent = `${currentYear}년 ${labelMap[mode]}`;

    if (isMonth) {
        // 현재 월 데이터로 복원
        if (reportData) renderSummaryTab(reportData);
        return;
    }

    // 기간 집계
    const months = PERIOD_MONTHS[mode];
    const filtered = yearlyCache.filter(r => months.includes(r.month));

    const totSalesBase     = filtered.reduce((s,r)=>s+(r.sales_base||0), 0);
    const totSalesTax      = filtered.reduce((s,r)=>s+(r.sales_tax||0), 0);
    const totBankTax       = filtered.reduce((s,r)=>s+(r.bank_deductible_tax||0), 0);
    const totCardTax       = filtered.reduce((s,r)=>s+(r.card_deductible_tax||0), 0);
    const totReverseTax    = filtered.reduce((s,r)=>s+(r.reverse_tax_total||0), 0);
    const totPurchaseTax   = filtered.reduce((s,r)=>s+(r.total_purchase_tax||0), 0);
    const totPayable       = totSalesTax - totPurchaseTax;

    document.getElementById('sum-salesBase').textContent        = fmtW(totSalesBase);
    document.getElementById('sum-salesTax').textContent         = fmtW(totSalesTax);
    document.getElementById('sum-bankTax').textContent          = fmtW(totBankTax);
    document.getElementById('sum-cardTax').textContent          = fmtW(totCardTax);
    document.getElementById('sum-reverseTax').textContent       = fmtW(totReverseTax);
    document.getElementById('sum-totalPurchaseTax').textContent = fmtW(totPurchaseTax);
    const payEl = document.getElementById('sum-taxPayable');
    payEl.textContent = (totPayable>=0?'납부 ':'환급 ') + fmtW(Math.abs(totPayable));
    payEl.className   = 'text-end fw-bold ' + (totPayable>=0?'c-red':'c-green');

    // 기간 납부세액 안내
    const pNote = document.getElementById('periodPayableNote');
    pNote.textContent = (totPayable>=0?'납부 ':'환급 ') + fmtW(Math.abs(totPayable));
    pNote.className   = totPayable>=0?'c-red':'c-green';

    // 월별 breakdown 테이블
    const statusLabel = { draft:'작성중', confirmed:'확정', filed:'신고완료' };
    const statusClass = { draft:'badge-draft', confirmed:'badge-confirmed', filed:'badge-filed' };
    document.getElementById('periodMonthRows').innerHTML = months.map(m => {
        const r = filtered.find(x=>x.month===m);
        if (!r) return `<tr class="text-muted"><td>${m}월</td><td colspan="4" class="text-center">미저장</td><td class="text-center"><span class="badge-draft">미저장</span></td></tr>`;
        const p = r.tax_payable||0;
        return `<tr style="cursor:pointer" onclick="selectMonth(${m});switchTab('summary',document.querySelector('[data-tab=summary]'))">
            <td>${m}월</td>
            <td class="text-end">${fmtW(r.sales_base)}</td>
            <td class="text-end c-blue">${fmtW(r.sales_tax)}</td>
            <td class="text-end c-green">${fmtW(r.total_purchase_tax)}</td>
            <td class="text-end ${p>=0?'c-red':'c-green'}">${p>=0?'납부 ':'환급 '}${fmtW(Math.abs(p))}</td>
            <td class="text-center"><span class="${statusClass[r.status]||'badge-draft'}">${statusLabel[r.status]||'작성중'}</span></td>
        </tr>`;
    }).join('');

    document.getElementById('ptSalesBase').textContent   = fmtW(totSalesBase);
    document.getElementById('ptSalesTax').textContent    = fmtW(totSalesTax);
    document.getElementById('ptPurchaseTax').textContent = fmtW(totPurchaseTax);
    const ptEl = document.getElementById('ptPayable');
    ptEl.textContent = (totPayable>=0?'납부 ':'환급 ') + fmtW(Math.abs(totPayable));
    ptEl.className   = 'text-end ' + (totPayable>=0?'c-red':'c-green');
}

function markPeriodFiled() {
    const months = PERIOD_MONTHS[currentSummaryMode];
    if (!months) return;
    const labelMap = { q1:'1기 예정', h1:'1기 확정', q3:'2기 예정', h2:'2기 확정' };
    if (!confirm(`${currentYear}년 ${labelMap[currentSummaryMode]} 기간의 모든 월을 신고완료 처리하시겠습니까?`)) return;
    Promise.all(months.map(m =>
        fetch(`/api/vat-report/report/${currentYear}/${m}`, {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ status:'filed' })
        }).then(r=>r.json())
    )).then(results => {
        const ok = results.filter(r=>r.success).length;
        showAlert(`${ok}개 월 신고완료 처리됐습니다.`);
        loadYearlyList();
    });
}

function printPeriodSummary() {
    const labelMap = { q1:'1기 예정(1~3월)', h1:'1기 확정(1~6월)', q3:'2기 예정(7~9월)', h2:'2기 확정(7~12월)' };
    const title = `${currentYear}년 ${labelMap[currentSummaryMode]} 부가가치세 신고서`;
    const salesBase     = document.getElementById('sum-salesBase').textContent;
    const salesTax      = document.getElementById('sum-salesTax').textContent;
    const bankTax       = document.getElementById('sum-bankTax').textContent;
    const cardTax       = document.getElementById('sum-cardTax').textContent;
    const reverseTax    = document.getElementById('sum-reverseTax').textContent;
    const totalPurchase = document.getElementById('sum-totalPurchaseTax').textContent;
    const taxPayable    = document.getElementById('sum-taxPayable').textContent;
    const w = window.open('','_blank','width=600,height=700');
    w.document.write(`<html><head><title>${title}</title>
    <style>body{font-family:Arial;padding:30px;font-size:14px}h2{color:#333}table{width:100%;border-collapse:collapse}td,th{border:1px solid #ccc;padding:8px 12px}th{background:#f0f0f0}.total{background:#fff3cd;font-weight:bold;font-size:16px}.blue{color:#004085}.green{color:#155724}.red{color:#721c24}</style>
    </head><body>
    <h2>${title}</h2>
    <p style="color:#666;font-size:12px">출력일: ${new Date().toLocaleDateString('ko-KR')}</p>
    <table><tbody>
        <tr><th colspan="2" class="blue">[ 매출세액 ]</th></tr>
        <tr><td>과세표준 (마진합계)</td><td align="right"><b>${salesBase}</b></td></tr>
        <tr><td>매출세액 (×10%)</td><td align="right" class="blue"><b>${salesTax}</b></td></tr>
        <tr><th colspan="2" class="green">[ 매입세액 공제 ]</th></tr>
        <tr><td>계좌 분류 공제매입세액</td><td align="right">${bankTax}</td></tr>
        <tr><td>법인카드 공제매입세액</td><td align="right">${cardTax}</td></tr>
        <tr><td>역발급 세금계산서</td><td align="right">${reverseTax}</td></tr>
        <tr><td><b>총 공제 매입세액</b></td><td align="right" class="green"><b>${totalPurchase}</b></td></tr>
        <tr class="total"><td>납부세액 (매출 - 매입)</td><td align="right">${taxPayable}</td></tr>
    </tbody></table>
    <br><p style="font-size:11px;color:#999">* 본 신고서는 ERP 시스템에서 자동 집계된 참고용 자료입니다.</p>
    <script>window.onload=()=>window.print()<\/script></body></html>`);
    w.document.close();
}

// ==================== 매출세액 계산 ====================
function calcSalesTax() {
    const base = parseFloat(document.getElementById('inputSalesBase').value) || 0;
    const tax  = Math.round(base * 0.1);
    document.getElementById('inputSalesTax').value = tax;
}

async function fetchIntegratedSales() {
    const btn = document.querySelector('[onclick="fetchIntegratedSales()"]');
    const origText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>집계 중...';
    btn.disabled = true;

    try {
        const res  = await fetch(`/api/integrated-settlement/monthly-margin?year=${currentYear}&month=${currentMonth}`);
        const data = await res.json();

        if (!data.success) throw new Error(data.message);

        const d = data.data;
        document.getElementById('inputSalesBase').value = Math.max(0, d.profit);
        calcSalesTax();

        // 상세 breakdown 표시
        const detail = [
            `📊 ${currentYear}년 ${currentMonth}월 통합정산 마진 집계`,
            ``,
            `즐길거리: ${fmtW(d.activity.margin)} (${d.activity.count}건)`,
            `  입금확정 ${fmtW(d.activity.received)} - 송금확정 ${fmtW(d.activity.sent)}`,
            ``,
            `호텔:    ${fmtW(d.hotel.margin)} (${d.hotel.count}건)`,
            `  입금확정 ${fmtW(d.hotel.received)} - 송금확정 ${fmtW(d.hotel.sent)}`,
            ``,
            `패키지:  ${fmtW(d.package.margin)} (${d.package.count}건)`,
            `  입금확정 ${fmtW(d.package.received)} - 송금확정 ${fmtW(d.package.sent)}`,
            ``,
            `────────────────────────`,
            `총 마진 (과세표준): ${fmtW(d.profit)}`,
            `매출세액 (×10%):   ${fmtW(d.sales_tax)}`,
        ].join('\n');

        alert(detail);
    } catch(e) {
        alert('통합정산 집계 실패: ' + e.message + '\n직접 마진 합계를 입력해주세요.');
    } finally {
        btn.innerHTML = origText;
        btn.disabled = false;
    }
}

// ==================== 저장 ====================
async function saveReport() {
    const sales_base = parseFloat(document.getElementById('inputSalesBase').value) || 0;
    const sales_tax  = parseFloat(document.getElementById('inputSalesTax').value)  || 0;
    const notes      = document.getElementById('reportNotes').value;

    try {
        const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sales_base, sales_tax, notes })
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        reportData = data.data;
        renderReport(data.data);
        loadYearlyList();
        showAlert('저장되었습니다.');
    } catch(e) { showAlert('저장 실패: ' + e.message, 'danger'); }
}

async function confirmReport() {
    if (!confirm('이 월의 부가세를 확정 처리하시겠습니까?')) return;
    await saveReport();
    const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'confirmed' })
    });
    const data = await res.json();
    if (data.success) { reportData = data.data; renderReport(data.data); loadYearlyList(); showAlert('확정 처리되었습니다.'); }
}

async function markFiled() {
    if (!confirm('신고 완료 처리하시겠습니까?')) return;
    const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'filed' })
    });
    const data = await res.json();
    if (data.success) { reportData = data.data; renderReport(data.data); loadYearlyList(); showAlert('신고완료 처리됐습니다.'); }
}

// ==================== 역발급 계산서 ====================
function openReverseModal() {
    const today = new Date().toISOString().slice(0,10);
    document.getElementById('rv-date').value     = today;
    document.getElementById('rv-supplier').value = '';
    document.getElementById('rv-total').value    = '';
    document.getElementById('rv-supply').value   = '';
    document.getElementById('rv-tax').value      = '';
    document.getElementById('rv-notes').value    = '';
    new bootstrap.Modal(document.getElementById('reverseModal')).show();
}

function calcReverseAuto() {
    const total = parseFloat(document.getElementById('rv-total').value) || 0;
    if (total > 0) {
        const supply = Math.round(total / 1.1);
        const tax    = total - supply;
        document.getElementById('rv-supply').value = supply;
        document.getElementById('rv-tax').value    = tax;
    }
}

function calcReverseTax() {
    const supply = parseFloat(document.getElementById('rv-supply').value) || 0;
    const tax    = Math.round(supply * 0.1);
    document.getElementById('rv-tax').value    = tax;
    document.getElementById('rv-total').value  = supply + tax;
}

async function saveReverseInvoice() {
    const date     = document.getElementById('rv-date').value;
    const supplier = document.getElementById('rv-supplier').value.trim();
    if (!date || !supplier) { alert('발급일과 업체명은 필수입니다.'); return; }

    const payload = {
        date,
        supplier_name:  supplier,
        total_amount:   parseFloat(document.getElementById('rv-total').value)  || 0,
        supply_amount:  parseFloat(document.getElementById('rv-supply').value) || 0,
        tax_amount:     parseFloat(document.getElementById('rv-tax').value)    || 0,
        notes:          document.getElementById('rv-notes').value,
    };

    try {
        const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}/reverse-invoice`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        reportData = data.data;
        renderReport(data.data);
        bootstrap.Modal.getInstance(document.getElementById('reverseModal')).hide();
        showAlert('역발급 계산서가 추가됐습니다.');
    } catch(e) { showAlert('추가 실패: ' + e.message, 'danger'); }
}

async function deleteReverseInvoice(id) {
    if (!confirm('삭제하시겠습니까?')) return;
    const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}/reverse-invoice/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) { reportData = data.data; renderReport(data.data); showAlert('삭제됐습니다.'); }
}

// ==================== 법인카드 업로드 ====================
async function uploadCardFile(input) {
    const file = input.files[0];
    if (!file) return;
    const formData = new FormData();
    formData.append('file', file);
    try {
        const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}/upload-card`, { method: 'POST', body: formData });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        reportData = data.data;
        renderReport(data.data);
        switchTab('card', document.querySelector('[data-tab="card"]'));
        showAlert(`${data.added}건 추가됐습니다. (총 ${data.total}건)`);
    } catch(e) { showAlert('업로드 실패: ' + e.message, 'danger'); }
    input.value = '';
}

async function toggleCardDeductible(id, val) {
    const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}/card/${id}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ deductible: val })
    });
    const data = await res.json();
    if (data.success) { reportData = data.data; renderReport(data.data); }
}

async function updateCardNote(id, notes) {
    await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}/card/${id}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ notes })
    });
}

async function clearCardExpenses() {
    if (!confirm('법인카드 내역을 전체 삭제하시겠습니까?')) return;
    const res  = await fetch(`/api/vat-report/report/${currentYear}/${currentMonth}`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ card_expenses: [] })
    });
    const data = await res.json();
    if (data.success) { reportData = data.data; renderReport(data.data); showAlert('삭제됐습니다.'); }
}

// ==================== 알림 ====================
function showAlert(msg, type = 'success') {
    const el = document.createElement('div');
    el.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
    el.style.cssText = 'top:80px;right:20px;z-index:9999;min-width:260px;font-size:.85rem';
    el.innerHTML = msg + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 3500);
}
</script>
</body>
</html>
