                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold small">공급가액</label>
                    <input type="number" class="form-control" id="rv-supply" placeholder="0" oninput="calcReverseTax()">
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold small">부가세</label>
                    <input type="number" class="form-control" id="rv-tax" placeholder="0">
                </div>
                <div class="col-12">
                    <label class="form-label fw-bold small">메모</label>
                    <input type="text" class="form-control" id="rv-notes" placeholder="">
