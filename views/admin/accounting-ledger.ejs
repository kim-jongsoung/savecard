<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>여행업 회계장부 / 신고자료 - 괌세이브카드 관리자</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <style>
        body { background:#f4f6fb; font-size:.83rem; }
        .period-badge { background:#1565c0; color:#fff; border-radius:6px; padding:4px 14px; font-size:.9rem; font-weight:700; }
        .card-is { border-left:4px solid #1565c0; }
        .card-bs { border-left:4px solid #37474f; }

        /* I/S 카드 */
        .is-box { border-radius:10px; padding:14px 18px; color:#fff; }
        .is-revenue  { background:linear-gradient(135deg,#1565c0,#1976d2); }
        .is-cost     { background:linear-gradient(135deg,#c62828,#e53935); }
        .is-margin   { background:linear-gradient(135deg,#2e7d32,#43a047); }

        /* B/S 카드 */
        .bs-box { border-radius:10px; padding:14px 18px; }
        .bs-asset   { background:#e3f2fd; border:2px solid #1565c0; color:#1565c0; }
        .bs-liability { background:#fff3e0; border:2px solid #e65100; color:#e65100; }

        /* 테이블 */
        th { white-space:nowrap; font-size:.77rem; padding:6px 8px !important; }
        td { padding:5px 8px !important; vertical-align:middle; }
        .num { text-align:right; white-space:nowrap; }
        .erp-badge-activity { background:#c8e6c9; color:#2e7d32; }
        .erp-badge-hotel    { background:#ffe0b2; color:#e65100; }
        .erp-badge-package  { background:#f3e5f5; color:#6a1b9a; }
        .text-conf { color:#1b5e20; font-weight:700; }
        .text-unconf { color:#b71c1c; }
        .status-paid   { background:#e8f5e9; color:#2e7d32; border-radius:4px; padding:1px 7px; font-size:.72rem; font-weight:600; }
        .status-unpaid { background:#ffebee; color:#c62828; border-radius:4px; padding:1px 7px; font-size:.72rem; font-weight:600; }

        /* 탭 */
        .nav-tabs .nav-link { font-size:.83rem; }
        .section-title { font-size:.85rem; font-weight:700; color:#37474f; border-bottom:2px solid #1565c0; padding-bottom:4px; margin-bottom:12px; }

        @media print {
            .no-print { display:none !important; }
            body { background:#fff; font-size:.78rem; }
            .container-fluid { padding:0 !important; }
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { currentPage: 'accounting-ledger', adminUsername: adminUsername || '관리자' }) %>

    <div class="container-fluid mt-3 pb-5">

        <!-- 헤더 -->
        <div class="d-flex align-items-center justify-content-between mb-3 no-print">
            <h4 class="mb-0 fw-bold"><i class="fas fa-file-invoice me-2 text-primary"></i>여행업 회계장부 / 신고자료 <small class="text-muted fs-6 fw-normal">(순액법 기준)</small></h4>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-success" onclick="exportExcel()"><i class="fas fa-file-excel me-1"></i>엑셀 다운로드</button>
                <button class="btn btn-sm btn-outline-secondary" onclick="window.print()"><i class="fas fa-print me-1"></i>인쇄</button>
            </div>
        </div>

        <!-- 핵심 안내 -->
        <div class="alert alert-warning py-2 mb-3 no-print" style="font-size:.8rem;">
            <i class="fas fa-exclamation-triangle me-1"></i>
            <strong>시점의 역설 방지:</strong>
            ① <strong>신고 대상 기간</strong>(연·월) = 출발일이 해당 기간인 건만 집계
            &nbsp;&nbsp;② <strong>신고 기준일</strong> = 이 날짜까지 출발한 건을 "출발완료"로 인식 → 미수금·미지급금 계상
            &nbsp;&nbsp;③ 기준일 이후 출발 예약의 선수금·선급비용은 신고 대상 제외(B/S 처리)
        </div>

        <!-- 기간 + 기준일 선택 -->
        <div class="card shadow-sm mb-3 no-print border-primary">
            <div class="card-header bg-primary text-white py-2" style="font-size:.83rem;">
                <i class="fas fa-calendar-check me-1"></i>
                <strong>신고 조건 설정</strong> — 아래 3가지를 설정한 후 조회하세요
            </div>
            <div class="card-body py-3">
                <div class="row g-3 align-items-end">
                    <div class="col-auto">
                        <label class="form-label small fw-bold mb-1">① 신고 연도</label>
                        <select class="form-select form-select-sm" id="selYear" style="width:100px"></select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small fw-bold mb-1">② 신고 단위</label>
                        <select class="form-select form-select-sm" id="selPeriodType" style="width:90px" onchange="onPeriodTypeChange()">
                            <option value="all">연간</option>
                            <option value="quarter">분기</option>
                            <option value="month" selected>월</option>
                        </select>
                    </div>
                    <div class="col-auto" id="colMonth">
                        <label class="form-label small fw-bold mb-1">월 선택</label>
                        <select class="form-select form-select-sm" id="selMonth" style="width:90px">
                            <option value="1">1월</option><option value="2">2월</option>
                            <option value="3">3월</option><option value="4">4월</option>
                            <option value="5">5월</option><option value="6">6월</option>
                            <option value="7">7월</option><option value="8">8월</option>
                            <option value="9">9월</option><option value="10">10월</option>
                            <option value="11">11월</option><option value="12">12월</option>
                        </select>
                    </div>
                    <div class="col-auto d-none" id="colQuarter">
                        <label class="form-label small fw-bold mb-1">분기 선택</label>
                        <select class="form-select form-select-sm" id="selQuarter" style="width:110px">
                            <option value="1">1분기 (1~3월)</option>
                            <option value="2">2분기 (4~6월)</option>
                            <option value="3">3분기 (7~9월)</option>
                            <option value="4">4분기 (10~12월)</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small fw-bold mb-1">
                            ③ 신고 기준일
                            <span class="text-danger">*</span>
                            <span class="text-muted fw-normal ms-1" style="font-size:.72rem">이 날까지 출발=완료로 인식</span>
                        </label>
                        <input type="date" class="form-control form-control-sm" id="selBaseDate" style="width:160px">
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-primary btn-sm px-4" onclick="loadReport()">
                            <i class="fas fa-search me-1"></i>신고자료 조회
                        </button>
                    </div>
                    <div class="col-auto align-self-center">
                        <span class="text-muted small" id="periodLabel"></span>
                    </div>
                </div>
                <div class="mt-2" style="font-size:.75rem; color:#666;">
                    <i class="fas fa-lightbulb text-warning me-1"></i>
                    <span id="periodExample">예) 2025년 3월 신고 → ① 2025년 &nbsp;② 단위:월 &nbsp;② 3월 &nbsp;③ 기준일: 2025-04-25 (신고서 작성일)</span><br>
                    <span style="color:#e65100">⚠ 분기 예) 2025년 1분기(1~3월) 신고 → ① 2025년 &nbsp;② 분기 &nbsp;② 1분기 &nbsp;③ 기준일: 2025-04-25</span>
                </div>
            </div>
        </div>

        <!-- 조회 전 안내 -->
        <div id="emptyGuide" class="text-center py-5">
            <i class="fas fa-calendar-alt fa-3x text-muted mb-3"></i>
            <div class="text-muted">위에서 신고 연도·월·기준일을 설정한 후 <strong>신고자료 조회</strong> 버튼을 누르세요.</div>
            <div class="text-muted small mt-1">기준일을 정확히 설정해야 미수금·미지급금이 올바르게 계상됩니다.</div>
        </div>

        <!-- 로딩 -->
        <div id="loadingArea" class="text-center py-5 d-none">
            <div class="spinner-border text-primary"></div>
            <div class="mt-2 text-muted small">출발일 기준 데이터 집계 중...</div>
        </div>

        <!-- 결과 영역 -->
        <div id="resultArea" class="d-none">

            <!-- ① 손익계산서 (I/S) -->
            <div class="mb-4">
                <div class="section-title"><i class="fas fa-chart-line me-1"></i>용역손익계산서 (I/S) — 출발일 기준 귀속 · 순액법</div>
                <div class="row g-3 mb-2">
                    <div class="col-12 col-md-4">
                        <div class="is-box is-revenue h-100">
                            <div class="small opacity-80 mb-1">총 수탁액 <span class="badge bg-white text-primary ms-1" style="font-size:.68rem">고객 납입 총액</span></div>
                            <div class="fw-bold fs-4" id="is_revenue">-</div>
                            <div class="small opacity-75 mt-1">
                                수령 확정: <span id="is_revenue_conf" class="fw-bold">-</span>
                                &nbsp;|&nbsp; 미수금: <span id="is_revenue_unconf">-</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="is-box is-cost h-100">
                            <div class="small opacity-80 mb-1">매입비용 <span class="badge bg-white text-danger ms-1" style="font-size:.68rem">랜드비·항공비 등</span></div>
                            <div class="fw-bold fs-4" id="is_cost">-</div>
                            <div class="small opacity-75 mt-1">
                                지급 확정: <span id="is_cost_conf" class="fw-bold">-</span>
                                &nbsp;|&nbsp; 미지급: <span id="is_cost_unconf">-</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="is-box is-margin h-100">
                            <div class="small opacity-80 mb-1">용역수입 (과세표준) <span class="badge bg-warning text-dark ms-1" style="font-size:.68rem">순액=부가세 신고기준</span></div>
                            <div class="fw-bold fs-4" id="is_margin">-</div>
                            <div class="small opacity-75 mt-1">
                                확정 용역수입: <span id="is_margin_conf" class="fw-bold">-</span>
                                &nbsp;|&nbsp; 수수료율: <span id="is_margin_rate">-</span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- I/S 상세 테이블 -->
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0" style="font-size:.8rem;">
                            <tbody>
                                <tr class="table-light"><td class="fw-bold" colspan="3">용역손익계산서 요약 (순액법 · 출발일 기준)</td></tr>
                                <tr>
                                    <td style="padding-left:20px">I. 총 수탁액 <span class="text-muted" style="font-size:.72rem">(고객 납입 총액 · 출발일 귀속)</span></td>
                                    <td class="num text-primary fw-bold" id="is_tbl_revenue">-</td>
                                    <td class="num text-muted" style="font-size:.73rem">수탁 예정</td>
                                </tr>
                                <tr>
                                    <td style="padding-left:36px" class="text-muted">ㄴ 수령 확정액</td>
                                    <td class="num text-conf" id="is_tbl_rev_conf">-</td>
                                    <td class="num text-muted" style="font-size:.73rem">실제 수령</td>
                                </tr>
                                <tr>
                                    <td style="padding-left:36px" class="text-muted">ㄴ 미수금 (출발후 미수령)</td>
                                    <td class="num text-danger" id="is_tbl_rev_unconf">-</td>
                                    <td class="num text-muted" style="font-size:.73rem">B/S 유동자산</td>
                                </tr>
                                <tr>
                                    <td style="padding-left:20px">II. 매입비용 <span class="text-muted" style="font-size:.72rem">(랜드비·항공비·숙박비 등)</span></td>
                                    <td class="num text-danger fw-bold" id="is_tbl_cost">-</td>
                                    <td class="num text-muted" style="font-size:.73rem">지급 예정</td>
                                </tr>
                                <tr>
                                    <td style="padding-left:36px" class="text-muted">ㄴ 지급 확정액</td>
                                    <td class="num text-conf" id="is_tbl_cost_conf">-</td>
                                    <td class="num text-muted" style="font-size:.73rem">실제 지급</td>
                                </tr>
                                <tr>
                                    <td style="padding-left:36px" class="text-muted">ㄴ 미지급금 (출발후 미지급)</td>
                                    <td class="num text-danger" id="is_tbl_cost_unconf">-</td>
                                    <td class="num text-muted" style="font-size:.73rem">B/S 유동부채</td>
                                </tr>
                                <tr class="table-success fw-bold">
                                    <td style="padding-left:20px">III. 용역수입 (I − II) <span class="badge bg-warning text-dark ms-1" style="font-size:.7rem">부가세 과세표준</span></td>
                                    <td class="num" id="is_tbl_margin">-</td>
                                    <td class="num text-muted" style="font-size:.73rem">순액 예정</td>
                                </tr>
                                <tr>
                                    <td style="padding-left:36px" class="text-muted">ㄴ 확정 용역수입 (수령확정 − 지급확정)</td>
                                    <td class="num text-conf" id="is_tbl_margin_conf">-</td>
                                    <td class="num text-muted" style="font-size:.73rem">실현 순액</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ② 재무상태표 잔액 (B/S) -->
            <div class="mb-4">
                <div class="section-title"><i class="fas fa-balance-scale me-1"></i>재무상태표 주요 잔액 (B/S) — 출발일 기준 시점 구분</div>
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <div class="bs-box bs-asset h-100">
                            <div class="small fw-bold mb-1">📥 미수금 <span class="fw-normal">(유동자산)</span></div>
                            <div class="fw-bold fs-5" id="bs_receivable">-</div>
                            <div class="small mt-1 opacity-75">출발 완료 · 수령 미완료<br><span style="font-size:.7rem">→ 신고 대상 포함, 미수령 상태</span></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bs-box bs-asset h-100">
                            <div class="small fw-bold mb-1">💰 선급비용 <span class="fw-normal">(유동자산)</span></div>
                            <div class="fw-bold fs-5" id="bs_prepaid">-</div>
                            <div class="small mt-1 opacity-75">출발 전 지급 완료<br><span style="font-size:.7rem">→ 행사 전 미리 송금한 매입비</span></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bs-box bs-liability h-100">
                            <div class="small fw-bold mb-1">📤 선수금 <span class="fw-normal">(유동부채)</span></div>
                            <div class="fw-bold fs-5" id="bs_deposit">-</div>
                            <div class="small mt-1 opacity-75">출발 전 수령 완료<br><span style="font-size:.7rem">→ 아직 신고 대상 아님 (미출발)</span></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="bs-box bs-liability h-100">
                            <div class="small fw-bold mb-1">💸 미지급금 <span class="fw-normal">(유동부채)</span></div>
                            <div class="fw-bold fs-5" id="bs_payable">-</div>
                            <div class="small mt-1 opacity-75">출발 완료 · 지급 미완료<br><span style="font-size:.7rem">→ 랜드사 등 미지급 매입비</span></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ③ 탭: 판매처별 / 공급업체별 / 거래 상세 -->
            <ul class="nav nav-tabs mb-3 no-print" id="detailTabs">
                <li class="nav-item"><button class="nav-link active" onclick="switchTab('platform',this)"><i class="fas fa-store me-1"></i>판매처별 수탁액</button></li>
                <li class="nav-item"><button class="nav-link" onclick="switchTab('vendor',this)"><i class="fas fa-building me-1"></i>공급업체별 매입비용</button></li>
                <li class="nav-item"><button class="nav-link" onclick="switchTab('detail',this)"><i class="fas fa-list me-1"></i>거래 상세</button></li>
            </ul>

            <!-- 판매처별 -->
            <div id="tab_platform">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-hover table-sm align-middle mb-0" style="font-size:.8rem;">
                            <thead class="table-dark">
                                <tr>
                                    <th>판매처 (채널)</th>
                                    <th class="num">건수</th>
                                    <th class="num">수탁액 (총 납입)</th>
                                    <th class="num">수령 확정액</th>
                                    <th class="num">미수금</th>
                                    <th class="num">용역수입 (순액)</th>
                                    <th class="num">수수료율</th>
                                </tr>
                            </thead>
                            <tbody id="tbl_platform"></tbody>
                            <tfoot id="tbl_platform_foot" class="fw-bold table-secondary"></tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- 공급업체별 -->
            <div id="tab_vendor" class="d-none">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-hover table-sm align-middle mb-0" style="font-size:.8rem;">
                            <thead class="table-dark">
                                <tr>
                                    <th>공급업체 (랜드사·호텔 등)</th>
                                    <th class="num">건수</th>
                                    <th class="num">매입비용 (예정)</th>
                                    <th class="num">지급 확정액</th>
                                    <th class="num">미지급금</th>
                                    <th class="num">미지급율</th>
                                </tr>
                            </thead>
                            <tbody id="tbl_vendor"></tbody>
                            <tfoot id="tbl_vendor_foot" class="fw-bold table-secondary"></tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- 거래 상세 -->
            <div id="tab_detail" class="d-none">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-hover table-sm align-middle mb-0" style="font-size:.78rem;min-width:1100px">
                            <thead class="table-dark">
                                <tr>
                                    <th>ERP</th>
                                    <th>출발일</th>
                                    <th>예약번호</th>
                                    <th>고객명</th>
                                    <th>판매처</th>
                                    <th>공급업체</th>
                                    <th class="num">수탁액</th>
                                    <th class="num">수령확정</th>
                                    <th>수령일</th>
                                    <th class="num">매입비용</th>
                                    <th class="num">지급확정</th>
                                    <th>지급일</th>
                                    <th class="num">용역수입(순액)</th>
                                    <th class="text-center">수탁상태</th>
                                    <th class="text-center">지급상태</th>
                                </tr>
                            </thead>
                            <tbody id="tbl_detail"></tbody>
                            <tfoot id="tbl_detail_foot" class="fw-bold table-secondary"></tfoot>
                        </table>
                    </div>
                </div>
            </div>

        </div><!-- /resultArea -->

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const krw  = v => v ? '₩' + Math.round(v).toLocaleString() : '-';
        const krw0 = v => '₩' + Math.round(v||0).toLocaleString();
        const pct  = (a,b) => b ? (a/b*100).toFixed(1)+'%' : '-';
        const fmtD = v => {
            if (!v) return '-';
            const d = new Date(v);
            if (isNaN(d)) return '-';
            return `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`;
        };

        let reportData = null;

        // 초기화: 연도 옵션 + 기준일 기본값, 자동 로드 없음
        (function init() {
            const sel = document.getElementById('selYear');
            const cur = new Date().getFullYear();
            for (let y = cur; y >= cur - 3; y--) {
                const o = document.createElement('option');
                o.value = y; o.textContent = y + '년';
                sel.appendChild(o);
            }
            // 현재 월 선택
            document.getElementById('selMonth').value = String(new Date().getMonth() + 1);
            // 기준일 기본값: 오늘
            const today = new Date();
            const yyyy = today.getFullYear();
            const mm   = String(today.getMonth()+1).padStart(2,'0');
            const dd   = String(today.getDate()).padStart(2,'0');
            document.getElementById('selBaseDate').value = `${yyyy}-${mm}-${dd}`;
        })();

        function onPeriodTypeChange() {
            const type = document.getElementById('selPeriodType').value;
            document.getElementById('colMonth').classList.toggle('d-none',   type !== 'month');
            document.getElementById('colQuarter').classList.toggle('d-none', type !== 'quarter');
        }

        async function loadReport() {
            const year     = document.getElementById('selYear').value;
            const type     = document.getElementById('selPeriodType').value;
            const baseDate = document.getElementById('selBaseDate').value;

            if (!baseDate) {
                alert('신고 기준일을 반드시 입력하세요.\n(예: 신고서 작성일 또는 신고 마감일)');
                return;
            }

            // 파라미터 구성
            let q = `year=${year}&baseDate=${baseDate}`;
            let periodTxt = '';
            if (type === 'month') {
                const month = document.getElementById('selMonth').value;
                q += `&month=${month}`;
                periodTxt = `${year}년 ${month}월`;
            } else if (type === 'quarter') {
                const quarter = document.getElementById('selQuarter').value;
                q += `&quarter=${quarter}`;
                const qLabels = {1:'1분기(1~3월)',2:'2분기(4~6월)',3:'3분기(7~9월)',4:'4분기(10~12월)'};
                periodTxt = `${year}년 ${qLabels[quarter]}`;
            } else {
                periodTxt = `${year}년 전체`;
            }

            document.getElementById('emptyGuide').classList.add('d-none');
            document.getElementById('loadingArea').classList.remove('d-none');
            document.getElementById('resultArea').classList.add('d-none');

            try {
                const res  = await fetch(`/api/accounting-ledger/report?${q}`);
                const data = await res.json();
                if (!data.success) throw new Error(data.message);
                reportData = data;

                document.getElementById('periodLabel').textContent =
                    `📅 ${periodTxt} | 기준일: ${baseDate} | 총 ${data.count}건`;

                renderIS(data.is, data.bs);
                renderBS(data.bs);
                renderPlatform(data.by_platform);
                renderVendor(data.by_vendor);
                renderDetail(data.rows);

                document.getElementById('loadingArea').classList.add('d-none');
                document.getElementById('resultArea').classList.remove('d-none');
            } catch(e) {
                document.getElementById('loadingArea').classList.add('d-none');
                document.getElementById('emptyGuide').classList.remove('d-none');
                alert('조회 실패: ' + e.message);
            }
        }

        function renderIS(is, bs) {
            const unrevConf  = is.revenue - is.revenue_confirmed;
            const uncostConf = is.cost    - is.cost_confirmed;
            const marginRate = is.revenue > 0 ? (is.margin / is.revenue * 100).toFixed(1) + '%' : '-';

            document.getElementById('is_revenue').textContent      = krw0(is.revenue);
            document.getElementById('is_revenue_conf').textContent = krw0(is.revenue_confirmed);
            document.getElementById('is_revenue_unconf').textContent = krw0(unrevConf);
            document.getElementById('is_cost').textContent         = krw0(is.cost);
            document.getElementById('is_cost_conf').textContent    = krw0(is.cost_confirmed);
            document.getElementById('is_cost_unconf').textContent  = krw0(uncostConf);
            document.getElementById('is_margin').textContent       = krw0(is.margin);
            document.getElementById('is_margin_conf').textContent  = krw0(is.margin_confirmed);
            document.getElementById('is_margin_rate').textContent  = marginRate;

            document.getElementById('is_tbl_revenue').textContent    = krw0(is.revenue);
            document.getElementById('is_tbl_rev_conf').textContent   = krw0(is.revenue_confirmed);
            document.getElementById('is_tbl_rev_unconf').textContent = krw0(bs.receivable);
            document.getElementById('is_tbl_cost').textContent       = krw0(is.cost);
            document.getElementById('is_tbl_cost_conf').textContent  = krw0(is.cost_confirmed);
            document.getElementById('is_tbl_cost_unconf').textContent= krw0(bs.payable);
            document.getElementById('is_tbl_margin').textContent     = krw0(is.margin);
            document.getElementById('is_tbl_margin_conf').textContent= krw0(is.margin_confirmed);
        }

        function renderBS(bs) {
            document.getElementById('bs_receivable').textContent = krw0(bs.receivable);
            document.getElementById('bs_prepaid').textContent    = krw0(bs.prepaid_cost);
            document.getElementById('bs_deposit').textContent    = krw0(bs.deposit_trust);
            document.getElementById('bs_payable').textContent    = krw0(bs.payable);
        }

        function renderPlatform(list) {
            const tbody = document.getElementById('tbl_platform');
            const tfoot = document.getElementById('tbl_platform_foot');
            if (!list.length) { tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-3">데이터 없음</td></tr>'; return; }
            let totRev=0, totConf=0, totMargin=0, totCount=0;
            tbody.innerHTML = list.map(p => {
                const unconf = p.revenue - p.revenue_confirmed;
                totRev   += p.revenue; totConf += p.revenue_confirmed;
                totMargin+= p.margin;  totCount+= p.count;
                return `<tr>
                    <td class="fw-bold">${p.platform}</td>
                    <td class="num">${p.count}</td>
                    <td class="num text-primary fw-bold">${krw0(p.revenue)}</td>
                    <td class="num text-conf">${krw0(p.revenue_confirmed)}</td>
                    <td class="num text-danger">${unconf>0?krw0(unconf):'-'}</td>
                    <td class="num ${p.margin>=0?'text-success':'text-danger'} fw-bold">${krw0(p.margin)}</td>
                    <td class="num">${pct(p.margin,p.revenue)}</td>
                </tr>`;
            }).join('');
            tfoot.innerHTML = `<tr><td>합계</td><td class="num">${totCount}</td><td class="num text-primary">${krw0(totRev)}</td><td class="num text-conf">${krw0(totConf)}</td><td class="num text-danger">${krw0(totRev-totConf)||'-'}</td><td class="num">${krw0(totMargin)}</td><td class="num">${pct(totMargin,totRev)}</td></tr>`;
        }

        function renderVendor(list) {
            const tbody = document.getElementById('tbl_vendor');
            const tfoot = document.getElementById('tbl_vendor_foot');
            if (!list.length) { tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">데이터 없음</td></tr>'; return; }
            let totCost=0, totConf=0, totCount=0;
            tbody.innerHTML = list.map(v => {
                const unpaid = v.cost - v.cost_confirmed;
                totCost += v.cost; totConf += v.cost_confirmed; totCount += v.count;
                return `<tr>
                    <td class="fw-bold">${v.vendor}</td>
                    <td class="num">${v.count}</td>
                    <td class="num text-danger fw-bold">${krw0(v.cost)}</td>
                    <td class="num text-conf">${krw0(v.cost_confirmed)}</td>
                    <td class="num text-danger">${unpaid>0?krw0(unpaid):'-'}</td>
                    <td class="num">${pct(unpaid,v.cost)}</td>
                </tr>`;
            }).join('');
            tfoot.innerHTML = `<tr><td>합계</td><td class="num">${totCount}</td><td class="num text-danger">${krw0(totCost)}</td><td class="num text-conf">${krw0(totConf)}</td><td class="num text-danger">${krw0(totCost-totConf)}</td><td class="num">${pct(totCost-totConf,totCost)}</td></tr>`;
        }

        function renderDetail(rows) {
            const tbody = document.getElementById('tbl_detail');
            const tfoot = document.getElementById('tbl_detail_foot');
            if (!rows.length) { tbody.innerHTML = '<tr><td colspan="15" class="text-center text-muted py-3">데이터 없음</td></tr>'; return; }
            let totRev=0, totRevConf=0, totCost=0, totCostConf=0, totMargin=0;
            tbody.innerHTML = rows.map(r => {
                totRev     += r.revenue;           totRevConf  += r.revenue_confirmed;
                totCost    += r.cost;              totCostConf += r.cost_confirmed;
                totMargin  += (r.revenue - r.cost);
                const margin = r.revenue - r.cost;
                const inStatus  = r.payment_received_date
                    ? `<span class="status-paid">수령완료</span>`
                    : (r.departed ? `<span class="status-unpaid">미수금</span>` : `<span class="badge bg-primary" style="font-size:.7rem">선수금(미출발)</span>`);
                const outStatus = r.payment_sent_date
                    ? `<span class="status-paid">지급완료</span>`
                    : (r.departed ? `<span class="status-unpaid">미지급금</span>` : `<span class="badge bg-secondary" style="font-size:.7rem">미출발</span>`);
                return `<tr>
                    <td><span class="badge erp-badge-${r.erp} px-2">${r.erp_label}</span></td>
                    <td style="white-space:nowrap">${fmtD(r.departure_date)}</td>
                    <td style="font-size:.73rem">${r.reservation_number||'-'}</td>
                    <td>${r.customer_name||'-'}</td>
                    <td style="font-size:.73rem">${r.platform_name||'-'}</td>
                    <td style="font-size:.73rem;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${r.vendor_name}">${r.vendor_name||'-'}</td>
                    <td class="num text-primary fw-bold">${krw0(r.revenue)}</td>
                    <td class="num text-conf">${r.revenue_confirmed>0?krw0(r.revenue_confirmed):'-'}</td>
                    <td style="white-space:nowrap;font-size:.73rem">${fmtD(r.payment_received_date)}</td>
                    <td class="num text-danger fw-bold">${krw0(r.cost)}</td>
                    <td class="num text-conf">${r.cost_confirmed>0?krw0(r.cost_confirmed):'-'}</td>
                    <td style="white-space:nowrap;font-size:.73rem">${fmtD(r.payment_sent_date)}</td>
                    <td class="num ${margin>=0?'text-success':'text-danger'} fw-bold">${krw0(margin)}</td>
                    <td class="text-center">${inStatus}</td>
                    <td class="text-center">${outStatus}</td>
                </tr>`;
            }).join('');
            tfoot.innerHTML = `<tr>
                <td colspan="6" class="text-end">합계 (${rows.length}건)</td>
                <td class="num text-primary">${krw0(totRev)}</td>
                <td class="num text-conf">${krw0(totRevConf)}</td><td></td>
                <td class="num text-danger">${krw0(totCost)}</td>
                <td class="num text-conf">${krw0(totCostConf)}</td><td></td>
                <td class="num ${totMargin>=0?'text-success':'text-danger'}">${krw0(totMargin)}</td>
                <td colspan="2"></td>
            </tr>`;
        }

        function switchTab(tab, btn) {
            ['platform','vendor','detail'].forEach(t => {
                document.getElementById('tab_'+t).classList.toggle('d-none', t!==tab);
            });
            document.querySelectorAll('#detailTabs .nav-link').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }

        // 엑셀 다운로드
        function exportExcel() {
            if (!reportData) { alert('먼저 신고자료를 조회하세요.'); return; }
            const { year, month } = reportData.period;
            const periodStr = month ? `${year}년${month}월` : `${year}년`;
            const wb = XLSX.utils.book_new();

            // I/S 시트
            const is = reportData.is; const bs = reportData.bs;
            const isData = [
                ['여행업 용역손익계산서 (순액법 · 출발일 기준)',''],
                ['기간', periodStr],
                ['',''],
                ['항목','금액','비고'],
                ['I. 총 수탁액 (고객 납입 총액)', is.revenue, '출발일 귀속'],
                ['  ㄴ 수령 확정액', is.revenue_confirmed, '실제 수령'],
                ['  ㄴ 미수금 (B/S 유동자산)', bs.receivable, '신고 대상 포함'],
                ['II. 매입비용 (랜드비·항공비·숙박비 등)', is.cost, '출발일 귀속'],
                ['  ㄴ 지급 확정액', is.cost_confirmed, '실제 지급'],
                ['  ㄴ 미지급금 (B/S 유동부채)', bs.payable, '랜드사 등 미지급'],
                ['III. 용역수입 (부가세 과세표준) = I - II', is.margin, '순액법 신고기준'],
                ['  ㄴ 확정 용역수입', is.margin_confirmed, '실현 순액'],
                ['','',''],
                ['[재무상태표 주요 잔액 B/S]','',''],
                ['미수금 (유동자산)', bs.receivable, '출발완료·미수령'],
                ['선급비용 (유동자산)', bs.prepaid_cost, '출발전·지급완료'],
                ['선수금 (유동부채)', bs.deposit_trust, '출발전·수령완료(신고제외)'],
                ['미지급금 (유동부채)', bs.payable, '출발완료·미지급'],
            ];
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(isData), 'I_S_요약');

            // 판매처별 시트
            const platData = [['판매처(채널)','건수','수탁액(총납입)','수령확정액','미수금','용역수입(순액)','수수료율']];
            reportData.by_platform.forEach(p => {
                platData.push([p.platform, p.count, p.revenue, p.revenue_confirmed, p.revenue-p.revenue_confirmed, p.margin, p.revenue>0?(p.margin/p.revenue*100).toFixed(1)+'%':'-']);
            });
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(platData), '판매처별_매출');

            // 공급업체별 시트
            const vendData = [['공급업체(랜드사·호텔등)','건수','매입비용(예정)','지급확정액','미지급금']];
            reportData.by_vendor.forEach(v => {
                vendData.push([v.vendor, v.count, v.cost, v.cost_confirmed, v.cost-v.cost_confirmed]);
            });
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(vendData), '공급업체별_매입');

            // 거래 상세 시트
            const detailData = [['ERP','출발일','예약번호','고객명','판매처','공급업체','수탁액','수령확정','수령일','매입비용','지급확정','지급일','용역수입(순액)','수탁상태','지급상태']];
            reportData.rows.forEach(r => {
                const inSt = r.payment_received_date ? '수령완료' : (r.departed ? '미수금' : '선수금(미출발)');
                const outSt= r.payment_sent_date ? '지급완료' : (r.departed ? '미지급금' : '미출발');
                detailData.push([
                    r.erp_label,
                    r.departure_date ? new Date(r.departure_date).toISOString().split('T')[0] : '-',
                    r.reservation_number||'-', r.customer_name||'-',
                    r.platform_name||'-', r.vendor_name||'-',
                    r.revenue, r.revenue_confirmed,
                    r.payment_received_date ? new Date(r.payment_received_date).toISOString().split('T')[0] : '-',
                    r.cost, r.cost_confirmed,
                    r.payment_sent_date ? new Date(r.payment_sent_date).toISOString().split('T')[0] : '-',
                    r.revenue - r.cost, inSt, outSt
                ]);
            });
            XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(detailData), '거래상세');

            XLSX.writeFile(wb, `여행업신고자료_순액법_${periodStr}_${new Date().toISOString().slice(0,10)}.xlsx`);
        }

        // 자동 로드 없음 — 사용자가 기간+기준일 설정 후 직접 조회
    </script>
</body>
</html>
