                            ${snapshot.inclusions ? `<div class="mb-2"><strong>포함사항:</strong><br><div class="alert alert-success mt-1" style="white-space: pre-line;">${snapshot.inclusions}</div></div>` : ''}
                            ${snapshot.exclusions ? `<div class="mb-2"><strong>불포함사항:</strong><br><div class="alert alert-warning mt-1" style="white-space: pre-line;">${snapshot.exclusions}</div></div>` : ''}
