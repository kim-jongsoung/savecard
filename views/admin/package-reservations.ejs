                const result = await response.json();

                if (result.success) {
                    const r = result.data;
                    const departureDate = new Date(r.travel_period.departure_date).toLocaleDateString('ko-KR');
                    const returnDate = new Date(r.travel_period.return_date).toLocaleDateString('ko-KR');

