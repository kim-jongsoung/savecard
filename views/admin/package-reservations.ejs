<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>패키지 예약 관리 - 괌세이브카드 관리자</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .status-badge {
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 0.85rem;
            font-weight: bold;
        }
        .status-pending { background-color: #fff3cd; color: #856404; }
        .status-confirmed { background-color: #d4edda; color: #155724; }
        .status-cancelled { background-color: #f8d7da; color: #721c24; }
        .action-icons .btn {
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
        }
        .component-icons {
            font-size: 1.2rem;
        }
        .margin-positive { color: #198754; font-weight: bold; }
        .margin-negative { color: #dc3545; font-weight: bold; }
        .last-edited-row {
            background-color: #fff3cd !important;
            border-left: 4px solid #ffc107 !important;
            transition: background-color 0.3s ease;
        }
        .last-edited-row:hover {
            background-color: #ffe69c !important;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { currentPage: 'package-reservations', adminUsername: adminUsername || '관리자' }) %>

    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2><i class="fas fa-box-open me-2"></i>패키지 예약 관리</h2>
                    <a href="/admin/package-inbox" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>새 패키지 예약 등록
                    </a>
                </div>

                <!-- 필터 -->
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-2">
                                <label class="form-label">날짜 기준</label>
                                <select class="form-select" id="dateTypeFilter">
                                    <option value="departure">출발일</option>
                                    <option value="created">예약일</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">시작일</label>
                                <input type="date" class="form-control" id="startDateFilter">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">종료일</label>
                                <input type="date" class="form-control" id="endDateFilter">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">예약 채널</label>
                                <select class="form-select" id="platformFilter">
                                    <option value="">전체</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">상태</label>
                                <select class="form-select" id="statusFilter">
                                    <option value="all">전체</option>
                                    <option value="pending">대기</option>
                                    <option value="confirmed">확정</option>
                                    <option value="cancelled">취소</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">검색</label>
                                <input type="text" class="form-control" id="searchInput" 
                                       placeholder="예약번호, 고객명">
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-md-12 text-end">
                                <button class="btn btn-primary" onclick="loadReservations()">
                                    <i class="fas fa-search me-1"></i>검색하기
                                </button>
                                <button class="btn btn-outline-secondary" onclick="resetFilters()">
                                    <i class="fas fa-redo me-1"></i>초기화
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 통계 -->
                <div class="row mb-3">
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="text-muted">총 예약</h6>
                                <h3 id="stat-total">0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="text-muted">총 거래액</h6>
                                <h3 id="stat-revenue">₩0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="text-muted">총 매입액</h6>
                                <h3 id="stat-cost">₩0</h3>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="text-muted">총 마진</h6>
                                <h3 id="stat-margin" class="margin-positive">₩0</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 예약 목록 -->
                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>출발일</th>
                                        <th>예약일</th>
                                        <th>예약채널</th>
                                        <th>예약번호</th>
                                        <th>상품명</th>
                                        <th>고객명</th>
                                        <th>여행기간</th>
                                        <th>인원</th>
                                        <th>구성요소</th>
                                        <th>상태</th>
                                        <th>관리</th>
                                    </tr>
                                </thead>
                                <tbody id="reservations-tbody">
                                    <tr>
                                        <td colspan="11" class="text-center">
                                            <div class="spinner-border text-primary" role="status">
                                                <span class="visually-hidden">로딩 중...</span>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 상세 모달 -->
    <div class="modal fade" id="detailModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">패키지 예약 상세</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="modal-body-content">
                    <!-- 동적으로 채워짐 -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">닫기</button>
                    <a href="#" id="edit-link" class="btn btn-primary">수정</a>
                </div>
            </div>
        </div>
    </div>

    <!-- 예약수정 모달 -->
    <div class="modal fade" id="editModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-edit me-2"></i>패키지 예약 수정</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
                    <form id="editForm">
                        <input type="hidden" id="edit_reservation_id">
                        
                        <!-- 기본 예약 정보 -->
                        <div>
                            <h6 style="font-size: 1rem; margin-bottom: 0.75rem;">📋 기본 예약 정보</h6>
                            
                            <!-- 예약번호 표시 -->
                            <div class="row mb-2">
                                <div class="col-md-12">
                                    <div class="alert alert-info py-2 mb-2">
                                        <strong>예약번호:</strong> <span id="edit_reservation_number_display"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- 한줄 요약 정보 -->
                            <div class="row mb-2">
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">예약 상태 *</label>
                                    <select class="form-select" id="edit_reservation_status" required>
                                        <option value="pending">⏳ 대기</option>
                                        <option value="confirmed">✅ 확정</option>
                                        <option value="cancelled">❌ 취소</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">예약채널 *</label>
                                    <input type="text" class="form-control" id="edit_platform_name" required>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">예약번호</label>
                                    <input type="text" class="form-control" id="edit_reservation_number_field" readonly style="background-color: #e9ecef;">
                                    <small class="text-muted">수정 불가</small>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">패키지명 *</label>
                                    <input type="text" class="form-control" id="edit_package_name" required>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">출발일 *</label>
                                    <input type="date" class="form-control" id="edit_departure_date" onchange="calculateEditNights()" required>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">귀국일 *</label>
                                    <input type="date" class="form-control" id="edit_return_date" onchange="calculateEditNights()" required>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">기간</label>
                                    <input type="text" class="form-control" id="edit_period_display" readonly placeholder="자동">
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-1">
                                    <label class="form-label" style="font-size: 0.875rem;">출국편명</label>
                                    <input type="text" class="form-control" id="edit_outbound_flight" placeholder="OZ601">
                                </div>
                                <div class="col-md-1">
                                    <label class="form-label" style="font-size: 0.875rem;">출발시간</label>
                                    <input type="time" class="form-control" id="edit_outbound_departure_time">
                                </div>
                                <div class="col-md-1">
                                    <label class="form-label" style="font-size: 0.875rem;">도착시간</label>
                                    <input type="time" class="form-control" id="edit_outbound_arrival_time">
                                </div>
                                <div class="col-md-1">
                                    <label class="form-label" style="font-size: 0.875rem;">입국편명</label>
                                    <input type="text" class="form-control" id="edit_inbound_flight" placeholder="OZ602">
                                </div>
                                <div class="col-md-1">
                                    <label class="form-label" style="font-size: 0.875rem;">출발시간</label>
                                    <input type="time" class="form-control" id="edit_inbound_departure_time">
                                </div>
                                <div class="col-md-1">
                                    <label class="form-label" style="font-size: 0.875rem;">도착시간</label>
                                    <input type="time" class="form-control" id="edit_inbound_arrival_time">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label" style="font-size: 0.875rem;">이용호텔</label>
                                    <input type="text" class="form-control" id="edit_hotel_name" placeholder="호텔명">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label" style="font-size: 0.875rem;">룸타입명</label>
                                    <input type="text" class="form-control" id="edit_room_type" placeholder="디럭스 오션뷰">
                                </div>
                            </div>

                            <!-- 인원 입력 -->
                            <h6 style="font-size: 0.95rem; margin-top: 1rem; margin-bottom: 0.75rem;">👥 인원 구성</h6>
                            <div class="row mb-2">
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">성인</label>
                                    <input type="number" class="form-control" id="edit_people_adult" value="0" min="0" onchange="generateEditGuestFields(); calculateEditTotalPrice();">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">소아</label>
                                    <input type="number" class="form-control" id="edit_people_child" value="0" min="0" onchange="generateEditGuestFields(); calculateEditTotalPrice();">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">유아</label>
                                    <input type="number" class="form-control" id="edit_people_infant" value="0" min="0" onchange="generateEditGuestFields(); calculateEditTotalPrice();">
                                </div>
                            </div>

                            <!-- 동적 고객 정보 필드 -->
                            <div id="edit_guests_container" class="mt-3"></div>

                            <!-- 일정 및 포함/불포함 사항 -->
                            <h6 style="font-size: 0.95rem; margin-top: 1rem; margin-bottom: 0.75rem;">📅 일정 및 포함/불포함 사항</h6>
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size: 0.875rem;">일정</label>
                                    <textarea class="form-control" id="edit_itinerary" rows="4" placeholder="1일차: 인천공항 출발 → 괌 도착&#10;2일차: 자유일정&#10;3일차: 시내관광&#10;4일차: 귀국"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size: 0.875rem;">포함사항</label>
                                    <textarea class="form-control" id="edit_inclusions" rows="2" placeholder="왕복항공권, 호텔숙박, 공항픽업, 조식 등"></textarea>
                                    <label class="form-label mt-2" style="font-size: 0.875rem;">불포함사항</label>
                                    <textarea class="form-control" id="edit_exclusions" rows="2" placeholder="개인경비, 선택관광, 여행자보험 등"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- 금액 정보 -->
                        <div class="section-divider" style="border-top: 1px solid #dee2e6; margin: 20px 0; padding-top: 20px;">
                            <h6 style="font-size: 1rem; margin-bottom: 0.75rem;">💰 금액 정보</h6>
                            
                            <!-- 인원별 판매가 -->
                            <h6 style="font-size: 0.95rem; margin-bottom: 0.75rem;">👥 인원별 판매가</h6>
                            <div class="row mb-2">
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">통화 *</label>
                                    <select class="form-select" id="edit_currency">
                                        <option value="KRW">KRW</option>
                                        <option value="USD">USD</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">환율</label>
                                    <input type="text" class="form-control" id="edit_exchange_rate" value="1,300" oninput="calculateEditSummary();">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">성인 1인 요금 *</label>
                                    <input type="text" class="form-control" id="edit_price_adult" placeholder="500,000" oninput="calculateEditTotalPrice();">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">소아 1인 요금</label>
                                    <input type="text" class="form-control" id="edit_price_child" placeholder="400,000" oninput="calculateEditTotalPrice();">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">유아 1인 요금</label>
                                    <input type="text" class="form-control" id="edit_price_infant" placeholder="100,000" oninput="calculateEditTotalPrice();">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 0.875rem;">총 판매가</label>
                                    <input type="text" class="form-control" id="edit_total_selling_price" readonly style="background-color: #e9ecef; font-weight: bold;">
                                </div>
                            </div>

                            <!-- 금액 변동 추가 항목 -->
                            <div class="row mt-2">
                                <div class="col-md-12">
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addEditPriceAdjustment()">
                                        <i class="fas fa-plus"></i> 금액 변동 추가
                                    </button>
                                </div>
                            </div>
                            <div id="edit_price_adjustments_container" class="mt-2"></div>

                            <!-- 결제 빌링 -->
                            <h6 style="font-size: 0.95rem; margin-top: 1rem; margin-bottom: 0.75rem;">💳 결제 빌링</h6>
                            <div id="edit_billings_container"></div>
                            <button type="button" class="btn btn-sm btn-outline-success mb-3" onclick="addEditBilling()">
                                <i class="fas fa-plus me-1"></i>결제 추가
                            </button>

                            <!-- 매입 구성요소 -->
                            <h6 style="font-size: 0.95rem; margin-top: 1rem; margin-bottom: 0.75rem;">📦 매입 구성요소</h6>
                            <div id="edit_components_container"></div>
                            <button type="button" class="btn btn-sm btn-outline-primary mb-3" onclick="addEditComponent()">
                                <i class="fas fa-plus me-1"></i>구성요소 추가
                            </button>
                            
                            <!-- 금액 요약 -->
                            <div class="summary-box mt-3">
                                <h6 style="font-size: 1rem; margin-bottom: 0.75rem;">💵 금액 요약</h6>
                                <div class="summary-row">
                                    <span><strong>총 판매가:</strong></span>
                                    <span id="edit_summary_revenue" style="font-weight: bold;">₩0</span>
                                </div>
                                <div id="edit_summary_revenue_detail" style="font-size: 0.8rem; color: #6c757d; margin-left: 10px; margin-bottom: 8px;"></div>
                                
                                <div class="summary-row">
                                    <span><strong>총 매입가:</strong></span>
                                    <span id="edit_summary_cost" style="font-weight: bold;">₩0</span>
                                </div>
                                <div id="edit_summary_cost_detail" style="font-size: 0.8rem; color: #6c757d; margin-left: 10px; margin-bottom: 8px;"></div>
                                
                                <div class="summary-row summary-total">
                                    <span>예상 마진:</span>
                                    <span id="edit_summary_margin">₩0 (0%)</span>
                                </div>
                                <div class="summary-row">
                                    <span>부가세 (마진의 10%):</span>
                                    <span id="edit_summary_vat">₩0</span>
                                </div>
                            </div>

                            <!-- 특별 요청사항 -->
                            <div class="mb-2 mt-3">
                                <label class="form-label" style="font-size: 0.875rem;">특별 요청사항</label>
                                <textarea class="form-control" id="edit_special_requests" rows="2" placeholder="특별 요청사항이 있으면 입력하세요"></textarea>
                            </div>
                        </div>

                        <!-- 수정 이력 -->
                        <div class="section-divider" style="border-top: 1px solid #dee2e6; margin: 20px 0; padding-top: 20px;">
                            <h6 style="font-size: 1rem; margin-bottom: 0.75rem;">📜 수정 이력</h6>
                            <div id="modification_history_container" style="max-height: 200px; overflow-y: auto;">
                                <p class="text-muted mb-0" style="font-size: 0.875rem;">수정 이력이 없습니다.</p>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>취소
                    </button>
                    <button type="button" class="btn btn-primary" onclick="saveReservationEdit()">
                        <i class="fas fa-save me-1"></i>저장
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 수배서 모달 -->
    <div class="modal fade" id="assignmentModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-file-alt me-2"></i>수배서 관리</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <!-- 기본 예약 정보 -->
                    <div class="card mb-3">
                        <div class="card-header bg-light">
                            <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>기본 예약 정보</h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3">
                                    <strong>예약번호:</strong> <span id="assign_reservation_number"></span>
                                </div>
                                <div class="col-md-3">
                                    <strong>고객명:</strong> <span id="assign_customer_name"></span>
                                </div>
                                <div class="col-md-3">
