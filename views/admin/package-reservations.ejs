                                       data-field="english_name"
                                       placeholder="HONG GILDONG">
                            </div>
                            <div class="col-md-2">
                                <label class="form-label" style="font-size: 0.875rem; margin-bottom: 0.25rem; font-weight: 500;">생년월일</label>
