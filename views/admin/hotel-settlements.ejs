                        </tr>
                    `;
                } else {
                    return `
                        <tr>
                            <td>${checkInDate}</td>
                            <td>${s.hotel_name || '-'}</td>
                            <td>${s.booking_agency_name || '-'}</td>
                            <td>${s.guest_name || '-'}</td>
                            <td class="text-end">$${sellingPriceUSD.toFixed(2)}</td>
                            <td class="text-end">₩${sellingPriceKRW.toLocaleString()}<br><small class="text-muted">(×${settlementRate.toFixed(2)})</small></td>
                            <td class="text-end">$${costPriceUSD.toFixed(2)}</td>
                            <td class="text-end">₩${costPriceKRW.toLocaleString()}<br><small class="text-muted">(×${displayRate.toFixed(2)})</small></td>
                            <td class="text-end">$${outHotelCostUSD.toFixed(2)}</td>
                            <td class="text-end">₩${outHotelCostKRW.toLocaleString()}<br><small class="text-muted">(×${displayRate.toFixed(2)})</small></td>
                            <td class="text-end">$${agencyFeeUSD.toFixed(2)}</td>
                            <td class="text-end">₩${agencyFeeKRW.toLocaleString()}<br><small class="text-muted">(×${settlementRate.toFixed(2)})</small></td>
                            <td class="text-end ${marginKRW >= 0 ? 'text-primary' : 'text-danger'}">₩${marginKRW.toLocaleString()}</td>
                            <td class="text-end">₩${tax.toLocaleString()}</td>
                            <td class="text-center" style="cursor:pointer;" onclick="editPaymentDate(${s.id}, 'received', '${s.payment_received_date ? new Date(s.payment_received_date).toISOString().split('T')[0] : ''}')" title="클릭하여 입금일 수정">
