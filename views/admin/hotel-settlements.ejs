        // 완료 탭 입금일/송금일 수정
        async function editPaymentDate(settlementId, type, currentDate) {
            const typeText = type === 'received' ? '입금일' : '송금일';
            const newDate = prompt(`${typeText}을 수정하세요 (YYYY-MM-DD):`, currentDate);
            if (!newDate || newDate === currentDate) return;

            // 날짜 형식 검증
            if (!/^\d{4}-\d{2}-\d{2}$/.test(newDate)) {
                alert('날짜 형식이 올바르지 않습니다. (예: 2025-03-01)');
                return;
            }

            try {
                const response = await fetch(`/api/hotel-settlements/${settlementId}/update-date`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type, date: newDate })
                });
                const result = await response.json();
                if (result.success) {
                    await loadSettlements();
                } else {
                    alert('날짜 수정 실패: ' + result.message);
                }
            } catch (error) {
                console.error('날짜 수정 실패:', error);
                alert('날짜 수정 중 오류가 발생했습니다.');
            }
        }

        // 탭 전환
        function switchTab(tab) {
            currentTab = tab;
            
            // 일괄 처리 버튼은 미완료 탭에서만 표시
            document.getElementById('bulkActions').style.display = tab === 'incomplete' ? 'block' : 'none';
            
            // 미완료 통계는 미완료 탭에서만 표시
            const incompleteStats = document.getElementById('incompleteStats');
            if (incompleteStats) {
                incompleteStats.style.display = tab === 'incomplete' ? 'flex' : 'none';
            }
            
            clearSelection();
            loadSettlements();
        }

        // 체크박스 선택
        function toggleSelection(id) {
            console.log('✅ 체크박스 토글:', id, typeof id);
            
            if (selectedIds.has(id)) {
                selectedIds.delete(id);
                console.log('➖ 선택 해제:', id);
            } else {
                selectedIds.add(id);
                console.log('➕ 선택 추가:', id);
            }
            
            console.log('📋 현재 선택된 ID 목록:', Array.from(selectedIds));
            
            // 선택된 항목이 있으면 일괄 처리 버튼 표시
            const bulkActions = document.getElementById('bulkActions');
            if (selectedIds.size > 0) {
                bulkActions.style.display = 'block';
            } else {
                bulkActions.style.display = 'none';
            }
        }

        // 전체 선택
        function toggleSelectAll() {
            const checkboxes = document.querySelectorAll('#incompleteList input[type="checkbox"]');
            const selectAll = document.getElementById('selectAll').checked;
            
            checkboxes.forEach(cb => {
                cb.checked = selectAll;
                const id = parseInt(cb.value);
                if (selectAll) {
                    selectedIds.add(id);
                } else {
                    selectedIds.delete(id);
                }
            });
            
            // 일괄 처리 버튼 표시/숨김
            const bulkActions = document.getElementById('bulkActions');
            bulkActions.style.display = selectedIds.size > 0 ? 'block' : 'none';
        }

        // 선택 해제
        function clearSelection() {
            selectedIds.clear();
            document.getElementById('selectAll').checked = false;
            document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
            document.getElementById('bulkActions').style.display = 'none';
        }

        // 일괄 입금/송금 처리
        async function bulkPayment(type) {
            if (selectedIds.size === 0) {
                alert('처리할 항목을 선택해주세요.');
                return;
            }

            const typeText = type === 'received' ? '입금' : '송금';
            const today = new Date().toISOString().split('T')[0];
            const date = prompt(`${typeText} 날짜를 입력하세요 (YYYY-MM-DD):`, today);
            
            if (!date) return;

            let exchangeRate = null;
            if (type === 'sent') {
                const rateInput = prompt('송금 환율을 입력하세요 (예: 1450):', '1450');
                if (!rateInput) return;
                exchangeRate = parseFloat(rateInput);
                if (isNaN(exchangeRate) || exchangeRate <= 0) {
                    alert('올바른 환율을 입력해주세요.');
                    return;
                }
            }

            if (!confirm(`선택한 ${selectedIds.size}개 항목을 ${typeText} 처리하시겠습니까?`)) {
                return;
            }

            const reservationIds = Array.from(selectedIds);
            console.log('🔍 선택된 예약 ID 목록:', reservationIds);
            console.log('🔍 전송할 데이터:', { reservation_ids: reservationIds, type, date, exchange_rate: exchangeRate });

            try {
                const response = await fetch('/api/hotel-settlements/bulk-payment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        reservation_ids: reservationIds,
                        type: type,
                        date: date,
                        exchange_rate: exchangeRate
                    })
                });

                const result = await response.json();
                console.log('💰 일괄 처리 결과:', result);

                if (result.success) {
                    alert(`✅ ${result.count || selectedIds.size}개 항목의 ${typeText} 처리가 완료되었습니다.\n\n처리된 날짜가 표시됩니다.`);
                    clearSelection();
                    // 강제 새로고침으로 최신 데이터 로드
                    await loadSettlements();
                    console.log('🔄 데이터 새로고침 완료');
                } else {
                    alert(`❌ ${typeText} 처리 실패: ` + result.message);
                }
            } catch (error) {
                console.error('일괄 처리 실패:', error);
                alert(`일괄 ${typeText} 처리 중 오류가 발생했습니다.`);
            }
        }

        // 일괄 입금/송금 취소 처리
        async function bulkCancelPayment(type) {
            if (selectedIds.size === 0) {
                alert('취소할 항목을 선택해주세요.');
