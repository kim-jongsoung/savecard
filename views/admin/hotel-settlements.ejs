        // 필터 초기화
        function resetFilters() {
            // 기간 초기화 (최근 3개월)
            const today = new Date();
            const threeMonthsAgo = new Date(today.getFullYear(), today.getMonth() - 3, 1);
            document.getElementById('startDate').valueAsDate = threeMonthsAgo;
            document.getElementById('endDate').valueAsDate = today;
            
            document.getElementById('filterAgency').value = '';
            document.getElementById('filterHotel').value = '';
            document.getElementById('filterGuest').value = '';
            document.getElementById('filterPaymentReceived').value = '';
            document.getElementById('filterPaymentSent').value = '';
            loadSettlements();
        }

        // 예약 상세 보기 (수배관리 페이지로 이동)
        function openReservationModal(reservationId) {
            // 수배관리 페이지로 이동하면서 자동으로 모달 열기
            window.location.href = `/admin/hotel-assignments?open=${reservationId}`;
        }

        // 미정산 엑셀 다운로드
        async function downloadIncompleteExcel() {
            try {
                // 현재 필터 조건으로 미정산 데이터 가져오기
                const startDate = document.getElementById('startDate').value;
                const endDate = document.getElementById('endDate').value;
                const agency = document.getElementById('filterAgency').value;
                const hotel = document.getElementById('filterHotel').value;
                const guest = document.getElementById('filterGuest').value;
                const paymentReceived = document.getElementById('filterPaymentReceived').value;
                const paymentSent = document.getElementById('filterPaymentSent').value;

                const params = new URLSearchParams({
                    status: 'incomplete'
                });

                if (startDate) params.append('start_date', startDate);
                if (endDate) params.append('end_date', endDate);
                if (agency) params.append('agency', agency);
                if (hotel) params.append('hotel', hotel);
                if (guest) params.append('guest', guest);
                if (paymentReceived) params.append('payment_received', paymentReceived);
                if (paymentSent) params.append('payment_sent', paymentSent);

                const response = await fetch(`/api/hotel-settlements-list?${params}`);
                const data = await response.json();

                if (!data.success || !data.data || data.data.length === 0) {
                    alert('다운로드할 데이터가 없습니다.');
                    return;
                }

                // 엑셀 데이터 생성
                const excelData = data.data.map(s => {
                    const sellingPriceUSD = parseFloat(s.total_selling_price || 0);
                    const costPriceUSD = parseFloat(s.total_cost_price || 0);
                    const outHotelCostUSD = parseFloat(s.out_hotel_cost || 0);
                    const agencyFeeUSD = parseFloat(s.agency_fee || 0);
                    
                    const settlementRate = parseFloat(s.exchange_rate || 1470);
                    const remittanceRate = parseFloat(s.remittance_rate || settlementRate);
                    const displayRate = remittanceRate;
                    
                    const sellingPriceKRW = Math.round(sellingPriceUSD * settlementRate);
                    const costPriceKRW = Math.round(costPriceUSD * displayRate);
                    const outHotelCostKRW = Math.round(outHotelCostUSD * displayRate);
                    const agencyFeeKRW = Math.round(agencyFeeUSD * settlementRate);
                    const marginKRW = sellingPriceKRW - costPriceKRW - outHotelCostKRW;
                    const tax = Math.round(marginKRW * 0.1);

                    const checkInDate = s.check_in_date ? new Date(s.check_in_date).toLocaleDateString('ko-KR') : '';
                    const paymentReceivedStatus = s.payment_received_date ? '완료' : '미완료';
                    const paymentSentStatus = s.payment_sent_date ? '완료' : '미완료';

                    return {
                        '체크인일': checkInDate,
                        '호텔명': s.hotel_name || '',
                        '예약업체': s.booking_agency_name || '',
                        '투숙객명': s.guest_name || '',
                        '거래액(USD)': sellingPriceUSD.toFixed(2),
                        '거래액(KRW)': sellingPriceKRW,
                        '정산환율': settlementRate.toFixed(2),
                        '호텔매입(USD)': costPriceUSD.toFixed(2),
                        '호텔매입(KRW)': costPriceKRW,
                        '송금환율': displayRate.toFixed(2),
                        '아웃호텔(USD)': outHotelCostUSD.toFixed(2),
                        '아웃호텔(KRW)': outHotelCostKRW,
                        '수배피(USD)': agencyFeeUSD.toFixed(2),
                        '수배피(KRW)': agencyFeeKRW,
                        '마진(KRW)': marginKRW,
                        '부가세(KRW)': tax,
                        '입금상태': paymentReceivedStatus,
                        '송금상태': paymentSentStatus
                    };
                });

                // 워크북 생성
                const wb = XLSX.utils.book_new();
                const ws = XLSX.utils.json_to_sheet(excelData);

                // 컬럼 너비 설정
                ws['!cols'] = [
                    { wch: 12 }, // 체크인일
                    { wch: 20 }, // 호텔명
                    { wch: 15 }, // 예약업체
                    { wch: 12 }, // 투숙객명
                    { wch: 12 }, // 거래액(USD)
                    { wch: 15 }, // 거래액(KRW)
                    { wch: 10 }, // 정산환율
                    { wch: 12 }, // 호텔매입(USD)
                    { wch: 15 }, // 호텔매입(KRW)
                    { wch: 10 }, // 송금환율
                    { wch: 12 }, // 아웃호텔(USD)
                    { wch: 15 }, // 아웃호텔(KRW)
                    { wch: 12 }, // 수배피(USD)
                    { wch: 15 }, // 수배피(KRW)
                    { wch: 15 }, // 마진(KRW)
                    { wch: 15 }, // 부가세(KRW)
                    { wch: 10 }, // 입금상태
                    { wch: 10 }  // 송금상태
                ];

                XLSX.utils.book_append_sheet(wb, ws, '미정산');

                // 파일명 생성 (날짜 포함)
                const today = new Date();
                const fileName = `호텔미정산_${today.getFullYear()}${String(today.getMonth()+1).padStart(2,'0')}${String(today.getDate()).padStart(2,'0')}.xlsx`;

                // 다운로드
                XLSX.writeFile(wb, fileName);

                alert(`엑셀 파일이 다운로드되었습니다.\n파일명: ${fileName}`);
            } catch (error) {
                console.error('엑셀 다운로드 실패:', error);
                alert('엑셀 다운로드 중 오류가 발생했습니다.');
            }
        }

        // 정산완료 엑셀 다운로드
        async function downloadExcel() {
            try {
                // 현재 필터 조건으로 완료 데이터 가져오기
                const startDate = document.getElementById('startDate').value;
                const endDate = document.getElementById('endDate').value;
                const agency = document.getElementById('filterAgency').value;
                const hotel = document.getElementById('filterHotel').value;
                const guest = document.getElementById('filterGuest').value;
                const paymentReceived = document.getElementById('filterPaymentReceived').value;
                const paymentSent = document.getElementById('filterPaymentSent').value;

                const params = new URLSearchParams({
                    status: 'completed'
                });

                if (startDate) params.append('start_date', startDate);
                if (endDate) params.append('end_date', endDate);
                if (agency) params.append('agency', agency);
                if (hotel) params.append('hotel', hotel);
                if (guest) params.append('guest', guest);
                if (paymentReceived) params.append('payment_received', paymentReceived);
                if (paymentSent) params.append('payment_sent', paymentSent);

                const response = await fetch(`/api/hotel-settlements-list?${params}`);
                const data = await response.json();

                if (!data.success || !data.data || data.data.length === 0) {
                    alert('다운로드할 데이터가 없습니다.');
                    return;
                }

                // 엑셀 데이터 생성
                const excelData = data.data.map(s => {
                    const sellingPriceUSD = parseFloat(s.total_selling_price || 0);
                    const costPriceUSD = parseFloat(s.total_cost_price || 0);
                    const outHotelCostUSD = parseFloat(s.out_hotel_cost || 0);
                    const agencyFeeUSD = parseFloat(s.agency_fee || 0);
                    
                    const settlementRate = parseFloat(s.exchange_rate || 1470);
                    const remittanceRate = parseFloat(s.remittance_rate || settlementRate);
                    const displayRate = remittanceRate;
                    
                    const sellingPriceKRW = Math.round(sellingPriceUSD * settlementRate);
                    const costPriceKRW = Math.round(costPriceUSD * displayRate);
                    const outHotelCostKRW = Math.round(outHotelCostUSD * displayRate);
                    const agencyFeeKRW = Math.round(agencyFeeUSD * settlementRate);
                    const marginKRW = sellingPriceKRW - costPriceKRW - outHotelCostKRW;
                    const tax = Math.round(marginKRW * 0.1);

                    const checkInDate = s.check_in_date ? new Date(s.check_in_date).toLocaleDateString('ko-KR') : '';
                    const paymentReceivedDate = s.payment_received_date ? new Date(s.payment_received_date).toLocaleDateString('ko-KR') : '';
                    const paymentSentDate = s.payment_sent_date ? new Date(s.payment_sent_date).toLocaleDateString('ko-KR') : '';

                    return {
                        '체크인일': checkInDate,
                        '호텔명': s.hotel_name || '',
                        '예약업체': s.booking_agency_name || '',
                        '투숙객명': s.guest_name || '',
                        '거래액(USD)': sellingPriceUSD.toFixed(2),
                        '거래액(KRW)': sellingPriceKRW,
                        '정산환율': settlementRate.toFixed(2),
                        '호텔매입(USD)': costPriceUSD.toFixed(2),
                        '호텔매입(KRW)': costPriceKRW,
                        '송금환율': displayRate.toFixed(2),
                        '아웃호텔(USD)': outHotelCostUSD.toFixed(2),
                        '아웃호텔(KRW)': outHotelCostKRW,
                        '수배피(USD)': agencyFeeUSD.toFixed(2),
                        '수배피(KRW)': agencyFeeKRW,
                        '마진(KRW)': marginKRW,
                        '부가세(KRW)': tax,
                        '입금일': paymentReceivedDate,
                        '송금일': paymentSentDate
                    };
                });

                // 워크북 생성
                const wb = XLSX.utils.book_new();
                const ws = XLSX.utils.json_to_sheet(excelData);

                // 컬럼 너비 설정
                ws['!cols'] = [
                    { wch: 12 }, // 체크인일
                    { wch: 20 }, // 호텔명
                    { wch: 15 }, // 예약업체
                    { wch: 12 }, // 투숙객명
                    { wch: 12 }, // 거래액(USD)
                    { wch: 15 }, // 거래액(KRW)
                    { wch: 10 }, // 정산환율
                    { wch: 12 }, // 호텔매입(USD)
                    { wch: 15 }, // 호텔매입(KRW)
                    { wch: 10 }, // 송금환율
                    { wch: 12 }, // 아웃호텔(USD)
                    { wch: 15 }, // 아웃호텔(KRW)
                    { wch: 12 }, // 수배피(USD)
                    { wch: 15 }, // 수배피(KRW)
                    { wch: 15 }, // 마진(KRW)
                    { wch: 15 }, // 부가세(KRW)
                    { wch: 12 }, // 입금일
                    { wch: 12 }  // 송금일
                ];

                XLSX.utils.book_append_sheet(wb, ws, '호텔정산');

                // 파일명 생성 (날짜 포함)
                const today = new Date();
                const fileName = `호텔정산_${today.getFullYear()}${String(today.getMonth()+1).padStart(2,'0')}${String(today.getDate()).padStart(2,'0')}.xlsx`;

                // 다운로드
                XLSX.writeFile(wb, fileName);

                alert(`엑셀 파일이 다운로드되었습니다.\n파일명: ${fileName}`);
            } catch (error) {
                console.error('엑셀 다운로드 실패:', error);
                alert('엑셀 다운로드 중 오류가 발생했습니다.');
            }
        }

        // ===== 정산현황 탭 =====
        const htKrw = v => '₩' + Math.round(v || 0).toLocaleString();
        async function loadHotelStatus() {
            const tbody = document.getElementById('hotelStatusBody');
            tbody.innerHTML = '<tr><td colspan="14" class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>';
            try {
                const res = await fetch('/api/integrated-settlement/status');
                const d = await res.json();
                if (!d.success) throw new Error(d.message);
                const list = d.list.filter(r => r.erp === 'hotel');
                document.getElementById('hotel_sum_deposit').textContent    = htKrw(list.reduce((s,r) => s+r.deposit, 0));
                document.getElementById('hotel_sum_receivable').textContent = htKrw(list.reduce((s,r) => s+r.receivable, 0));
                document.getElementById('hotel_sum_prepaid').textContent    = htKrw(list.reduce((s,r) => s+r.prepaid, 0));
                document.getElementById('hotel_sum_payable').textContent    = htKrw(list.reduce((s,r) => s+r.payable, 0));
                if (!list.length) { tbody.innerHTML = '<tr><td colspan="14" class="text-center py-4 text-muted">데이터가 없습니다.</td></tr>'; return; }
                tbody.innerHTML = list.map(r => {
                    const dep = r.departure_date ? new Date(r.departure_date).toLocaleDateString('ko-KR',{month:'2-digit',day:'2-digit'}) : '-';
                    const mc = (r.margin||0) >= 0 ? 'text-success' : 'text-danger';
                    let badge = '';
                    if (r.receivable > 0) badge += '<span class="badge bg-danger me-1">미수금</span>';
                    if (r.deposit > 0)    badge += '<span class="badge bg-success me-1">수탁</span>';
                    if (r.payable > 0)    badge += '<span class="badge bg-warning text-dark me-1">미지급</span>';
                    if (r.prepaid > 0)    badge += '<span class="badge bg-primary me-1">선급</span>';
                    if (!badge)           badge  = '<span class="badge bg-secondary">완료</span>';
                    return `<tr class="${r.departed ? '' : 'table-light'}">
                        <td>${dep}</td>
                        <td><small>${r.reservation_number||'-'}</small></td>
                        <td><small>${r.platform_name||'-'}</small></td>
                        <td>${r.customer_name||'-'}</td>
                        <td class="text-end">${htKrw(r.total_selling)}</td>
                        <td class="text-end">${htKrw(r.received_amount)}</td>
                        <td class="text-end text-success fw-bold">${r.deposit>0?htKrw(r.deposit):'-'}</td>
                        <td class="text-end text-danger fw-bold">${r.receivable>0?htKrw(r.receivable):'-'}</td>
                        <td class="text-end">${r.total_cost>0?htKrw(r.total_cost):'-'}</td>
                        <td class="text-end">${r.sent_amount>0?htKrw(r.sent_amount):'-'}</td>
                        <td class="text-end text-primary fw-bold">${r.prepaid>0?htKrw(r.prepaid):'-'}</td>
                        <td class="text-end text-warning fw-bold">${r.payable>0?htKrw(r.payable):'-'}</td>
                        <td class="text-end fw-bold ${mc}">${htKrw(r.margin)}</td>
                        <td>${badge}</td>
                    </tr>`;
                }).join('');
            } catch(e) {
                tbody.innerHTML = `<tr><td colspan="14" class="text-center py-4 text-danger">로드 실패: ${e.message}</td></tr>`;
            }
        }
    </script>
</body>
</html>
