                } else {
                    alert(`❌ ${typeText} 취소 실패: ` + result.message);
                }
            } catch (error) {
                console.error('일괄 취소 실패:', error);
                alert(`일괄 ${typeText} 취소 중 오류가 발생했습니다.`);
            }
