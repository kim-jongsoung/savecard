<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>호텔 정산관리 - 괌세이브카드</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/erp-common.css">
    <style>
        /* 페이지 전용 스타일 */
        .table td { border-right: 1px solid #dee2e6; }
        .table th { border-right: 1px solid #dee2e6; }
        .table td:last-child, .table th:last-child { border-right: none; }
        .status-complete { background: #28a745 !important; color: white !important; }
        .status-incomplete { background: #ffc107 !important; color: #000 !important; }
    </style>
</head>
<body>
    <!-- 네비게이션 -->
    <%- include('../partials/navbar', { currentPage: 'hotel-settlements', adminUsername: adminUsername || '관리자' }) %>

    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-calculator me-2"></i>호텔 정산관리</h2>
        </div>

        <!-- 필터링 섹션 -->
        <div class="filter-section">
            <div class="row g-2 mb-2">
                <div class="col-md-3">
                    <label class="form-label">기간</label>
                    <div class="input-group input-group-sm">
                        <input type="date" class="form-control" id="startDate">
                        <span class="input-group-text">~</span>
                        <input type="date" class="form-control" id="endDate">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">예약업체</label>
                    <select class="form-select form-select-sm" id="filterAgency">
                        <option value="">전체</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">호텔</label>
                    <select class="form-select form-select-sm" id="filterHotel">
                        <option value="">전체</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">투숙객명</label>
                    <input type="text" class="form-control form-control-sm" id="filterGuest" placeholder="고객명 검색">
                </div>
                <div class="col-md-1">
                    <label class="form-label">입금</label>
                    <select class="form-select form-select-sm" id="filterPaymentReceived">
                        <option value="">전체</option>
                        <option value="completed">완료</option>
                        <option value="incomplete">미완료</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label">송금</label>
                    <select class="form-select form-select-sm" id="filterPaymentSent">
                        <option value="">전체</option>
                        <option value="completed">완료</option>
                        <option value="incomplete">미완료</option>
                    </select>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button class="btn btn-primary btn-sm w-100" onclick="loadSettlements()">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
            <div class="row g-2">
                <div class="col-md-12 text-end">
                    <button class="btn btn-secondary btn-sm" onclick="resetFilters()">
                        <i class="fas fa-redo me-1"></i>초기화
                    </button>
                </div>
            </div>
        </div>

        <!-- 탭 -->
        <ul class="nav nav-tabs mb-3" id="settlementTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="incomplete-tab" data-bs-toggle="tab" data-bs-target="#incomplete" 
                        type="button" role="tab" onclick="switchTab('incomplete')">
                    미완료
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="complete-tab" data-bs-toggle="tab" data-bs-target="#complete" 
                        type="button" role="tab" onclick="switchTab('complete')">
                    완료
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="hotelstatus-tab" data-bs-toggle="tab" data-bs-target="#hotelStatusPane"
                        type="button" role="tab" onclick="loadHotelStatus()">
                    <i class="fas fa-chart-bar me-1"></i>정산현황
                </button>
            </li>
        </ul>

        <!-- 일괄 처리 버튼 (미완료 탭에만 표시) -->
        <div id="bulkActions" class="mb-3" style="display: none;">
            <button class="btn btn-success btn-sm" onclick="bulkPayment('received')">
                <i class="fas fa-arrow-down me-1"></i>선택 항목 일괄 입금
            </button>
            <button class="btn btn-danger btn-sm" onclick="bulkPayment('sent')">
                <i class="fas fa-arrow-up me-1"></i>선택 항목 일괄 송금
            </button>
            <button class="btn btn-warning btn-sm" onclick="bulkCancelPayment('received')">
                <i class="fas fa-undo me-1"></i>선택 항목 일괄 입금 취소
            </button>
            <button class="btn btn-info btn-sm" onclick="bulkCancelPayment('sent')">
                <i class="fas fa-undo me-1"></i>선택 항목 일괄 송금 취소
            </button>
            <button class="btn btn-outline-secondary btn-sm" onclick="clearSelection()">
                <i class="fas fa-times me-1"></i>선택 해제
            </button>
        </div>

        <!-- 탭 컨텐츠 -->
        <div class="tab-content" id="settlementTabContent">
            <!-- 미완료 탭 -->
            <div class="tab-pane fade show active" id="incomplete" role="tabpanel">
                <!-- 엑셀 다운로드 버튼 -->
                <div class="mb-3 text-end">
                    <button class="btn btn-success btn-sm" onclick="downloadIncompleteExcel()">
                        <i class="fas fa-file-excel me-1"></i>엑셀 다운로드
                    </button>
                </div>
                <!-- 미완료 통계 -->
                <div class="row mb-3" id="incompleteStats">
                    <div class="col-md-6">
                        <div class="card border-warning">
                            <div class="card-body py-2">
                                <h6 class="card-title mb-1">
                                    <i class="fas fa-arrow-down text-success"></i> 입금완료 / 송금미완료
                                </h6>
                                <h4 class="mb-0 text-warning" id="receivedOnlyTotal">₩0</h4>
                                <small class="text-muted" id="receivedOnlyCount">0건</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-danger">
                            <div class="card-body py-2">
                                <h6 class="card-title mb-1">
                                    <i class="fas fa-arrow-up text-danger"></i> 송금완료 / 입금미완료
                                </h6>
                                <h4 class="mb-0 text-danger" id="sentOnlyTotal">₩0</h4>
                                <small class="text-muted" id="sentOnlyCount">0건</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-sm">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 40px;">
                                    <input type="checkbox" class="form-check-input" id="selectAll" onchange="toggleSelectAll()">
                                </th>
                                <th>체크인</th>
                                <th>호텔명</th>
                                <th>예약업체</th>
                                <th>투숙객명</th>
                                <th class="text-end" colspan="2">거래액</th>
                                <th class="text-end" colspan="2">호텔매입</th>
                                <th class="text-end" colspan="2">아웃호텔</th>
                                <th class="text-end" colspan="2">수배피</th>
                                <th class="text-end">마진</th>
                                <th class="text-end">부가세</th>
                                <th class="text-center">입금</th>
                                <th class="text-center">송금</th>
                            </tr>
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th class="text-end" style="font-size: 0.75rem;">USD</th>
                                <th class="text-end" style="font-size: 0.75rem;">KRW</th>
                                <th class="text-end" style="font-size: 0.75rem;">USD</th>
                                <th class="text-end" style="font-size: 0.75rem;">KRW</th>
                                <th class="text-end" style="font-size: 0.75rem;">USD</th>
                                <th class="text-end" style="font-size: 0.75rem;">KRW</th>
                                <th class="text-end" style="font-size: 0.75rem;">USD</th>
                                <th class="text-end" style="font-size: 0.75rem;">KRW</th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="incompleteList">
                            <tr>
                                <td colspan="17" class="text-center py-5">
                                    <i class="fas fa-spinner fa-spin fa-2x text-muted"></i>
                                    <p class="mt-2 text-muted">데이터를 불러오는 중...</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 완료 탭 -->
            <div class="tab-pane fade" id="complete" role="tabpanel">
                <!-- 엑셀 다운로드 버튼 -->
                <div class="mb-3 text-end">
                    <button class="btn btn-success btn-sm" onclick="downloadExcel()">
                        <i class="fas fa-file-excel me-1"></i>엑셀 다운로드
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>체크인</th>
                                <th>호텔명</th>
                                <th>예약업체</th>
                                <th>투숙객명</th>
                                <th class="text-end" colspan="2">거래액</th>
                                <th class="text-end" colspan="2">호텔매입</th>
                                <th class="text-end" colspan="2">아웃호텔</th>
                                <th class="text-end" colspan="2">수배피</th>
                                <th class="text-end">마진</th>
                                <th class="text-end">부가세</th>
                                <th class="text-center">입금일</th>
                                <th class="text-center">송금일</th>
                            </tr>
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th class="text-end" style="font-size: 0.75rem;">USD</th>
                                <th class="text-end" style="font-size: 0.75rem;">KRW</th>
                                <th class="text-end" style="font-size: 0.75rem;">USD</th>
                                <th class="text-end" style="font-size: 0.75rem;">KRW</th>
                                <th class="text-end" style="font-size: 0.75rem;">USD</th>
                                <th class="text-end" style="font-size: 0.75rem;">KRW</th>
                                <th class="text-end" style="font-size: 0.75rem;">USD</th>
                                <th class="text-end" style="font-size: 0.75rem;">KRW</th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="completeList">
                            <tr>
                                <td colspan="16" class="text-center py-5">
                                    <i class="fas fa-spinner fa-spin fa-2x text-muted"></i>
                                    <p class="mt-2 text-muted">데이터를 불러오는 중...</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- 정산현황 탭 패널 -->
            <div class="tab-pane fade" id="hotelStatusPane" role="tabpanel">
                <div class="row g-3 mb-3">
                    <div class="col-6 col-md-3">
                        <div class="card border-success"><div class="card-body py-2 px-3">
                            <div class="small text-muted">수탁액 <span class="badge bg-success ms-1">출발전 입금</span></div>
                            <div class="fw-bold fs-6 text-success" id="hotel_sum_deposit">-</div>
                        </div></div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-danger"><div class="card-body py-2 px-3">
                            <div class="small text-muted">미수금 <span class="badge bg-danger ms-1">출발후 미입금</span></div>
                            <div class="fw-bold fs-6 text-danger" id="hotel_sum_receivable">-</div>
                        </div></div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-primary"><div class="card-body py-2 px-3">
                            <div class="small text-muted">선급금 <span class="badge bg-primary ms-1">출발전 송금</span></div>
                            <div class="fw-bold fs-6 text-primary" id="hotel_sum_prepaid">-</div>
                        </div></div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-warning"><div class="card-body py-2 px-3">
                            <div class="small text-muted">미지급금 <span class="badge bg-warning text-dark ms-1">출발후 미송금</span></div>
                            <div class="fw-bold fs-6 text-warning" id="hotel_sum_payable">-</div>
                        </div></div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size:.82rem">
                        <thead class="table-dark"><tr>
                            <th>체크인</th><th>예약번호</th><th>예약업체</th><th>투숙객명</th>
                            <th class="text-end">판매(KRW)</th><th class="text-end">입금액</th>
                            <th class="text-end text-success">수탁액</th><th class="text-end text-danger">미수금</th>
                            <th class="text-end">매입(KRW)</th><th class="text-end">송금액</th>
                            <th class="text-end text-primary">선급금</th><th class="text-end text-warning">미지급금</th>
                            <th class="text-end">손익</th><th>상태</th>
                        </tr></thead>
                        <tbody id="hotelStatusBody"><tr><td colspan="14" class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- 모달은 수배관리 페이지에서 사용 -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <script>
        let currentTab = 'incomplete';
        let selectedIds = new Set();

        // 페이지 로드 시
        document.addEventListener('DOMContentLoaded', function() {
            // 기본 날짜 설정 (최근 3개월)
            const today = new Date();
            const threeMonthsAgo = new Date(today.getFullYear(), today.getMonth() - 3, 1);
            document.getElementById('startDate').valueAsDate = threeMonthsAgo;
            document.getElementById('endDate').valueAsDate = today;
            
            // 필터 옵션 로드
            loadFilterOptions();
            
            // 정산 목록 로드 (미완료 탭은 전체, 완료 탭은 기간 필터)
            loadSettlements();
        });

        // 필터 옵션 로드
        async function loadFilterOptions() {
            try {
                // 예약업체 목록
                console.log('🔍 예약업체 목록 API 호출...');
                const agencyRes = await fetch('/api/hotel-settlements/agencies');
                console.log('📡 예약업체 응답 상태:', agencyRes.status);
                if (!agencyRes.ok) {
                    const errorText = await agencyRes.text();
                    console.error('❌ 예약업체 목록 로드 실패:', agencyRes.status, errorText);
                    // 실패해도 계속 진행
                } else {
                    const agencies = await agencyRes.json();
                    console.log('📦 예약업체 데이터:', agencies);
                    const agencySelect = document.getElementById('filterAgency');
                    if (Array.isArray(agencies)) {
                        agencies.forEach(agency => {
                            const option = document.createElement('option');
                            option.value = agency.agency_name;
                            option.textContent = agency.agency_name;
                            agencySelect.appendChild(option);
                        });
                    }
                }

                // 호텔 목록
                const hotelRes = await fetch('/api/hotel-settlements/hotels');
                if (!hotelRes.ok) {
                    console.error('호텔 목록 로드 실패:', hotelRes.status);
                    return;
                }
                const hotels = await hotelRes.json();
                const hotelSelect = document.getElementById('filterHotel');
                if (Array.isArray(hotels)) {
                    hotels.forEach(hotel => {
                        const option = document.createElement('option');
                        option.value = hotel.hotel_name;
                        option.textContent = hotel.hotel_name;
                        hotelSelect.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('필터 옵션 로드 실패:', error);
            }
        }

        // 정산 목록 로드
        async function loadSettlements() {
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;
            const agency = document.getElementById('filterAgency').value;
            const hotel = document.getElementById('filterHotel').value;
            const guest = document.getElementById('filterGuest').value;
            const paymentReceived = document.getElementById('filterPaymentReceived').value;
            const paymentSent = document.getElementById('filterPaymentSent').value;

            const params = new URLSearchParams({
                status: currentTab === 'incomplete' ? 'incomplete' : 'completed'
            });

            // 기간 필터 (항상 적용)
            if (startDate) params.append('start_date', startDate);
            if (endDate) params.append('end_date', endDate);

            if (agency) params.append('agency', agency);
            if (hotel) params.append('hotel', hotel);
            if (guest) params.append('guest', guest);
            if (paymentReceived) params.append('payment_received', paymentReceived);
            if (paymentSent) params.append('payment_sent', paymentSent);

            try {
                console.log('🔍 API 호출:', `/api/hotel-settlements-list?${params}`);
                const response = await fetch(`/api/hotel-settlements-list?${params}`);
                console.log('📡 응답 상태:', response.status);
                const data = await response.json();
                console.log('📦 응답 데이터:', data);

                if (data.success) {
                    renderSettlements(data.data);
                } else {
                    console.error('❌ 데이터 로드 실패:', data.message);
                    alert('데이터 로드 실패: ' + data.message);
                }
            } catch (error) {
                console.error('❌ 정산 목록 로드 실패:', error);
                alert('정산 목록을 불러오는데 실패했습니다.');
            }
        }

        // 정산 목록 렌더링
        function renderSettlements(settlements) {
            const listId = currentTab === 'incomplete' ? 'incompleteList' : 'completeList';
            const tbody = document.getElementById(listId);

            if (!settlements || settlements.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="${currentTab === 'incomplete' ? 17 : 16}" class="text-center py-5">
                            <i class="fas fa-inbox fa-2x text-muted"></i>
                            <p class="mt-2 text-muted">정산 데이터가 없습니다</p>
                        </td>
                    </tr>
                `;
                return;
            }

            // 합계 계산용 변수
            let totalSellingUSD = 0, totalSellingKRW = 0;
            let totalCostUSD = 0, totalCostKRW = 0;
            let totalOutHotelUSD = 0, totalOutHotelKRW = 0;
            let totalAgencyFeeUSD = 0, totalAgencyFeeKRW = 0;
            let totalMarginKRW = 0, totalTax = 0;
            
            // 미완료 탭 통계용 변수
            let receivedOnlyTotal = 0, receivedOnlyCount = 0;
            let sentOnlyTotal = 0, sentOnlyCount = 0;

            const rows = settlements.map(s => {
                const sellingPriceUSD = parseFloat(s.total_selling_price || 0);
                const costPriceUSD = parseFloat(s.total_cost_price || 0);
                const outHotelCostUSD = parseFloat(s.out_hotel_cost || 0);
                const agencyFeeUSD = parseFloat(s.agency_fee || 0);
                
                const settlementRate = parseFloat(s.exchange_rate || 1470);
                const remittanceRate = parseFloat(s.remittance_rate || settlementRate);
                
                const isPaymentSent = !!s.payment_sent_date;
                const displayRate = isPaymentSent ? remittanceRate : settlementRate;
                
                // 디버깅: 환율 정보 확인
                if (isPaymentSent) {
                    console.log('💱 송금 완료 건 환율:', {
                        id: s.id,
                        settlementRate,
                        remittanceRate,
                        displayRate,
                        isPaymentSent
                    });
                }
                
                const sellingPriceKRW = Math.round(sellingPriceUSD * settlementRate);
                const costPriceKRW = Math.round(costPriceUSD * displayRate);
                const outHotelCostKRW = Math.round(outHotelCostUSD * displayRate);
                const agencyFeeKRW = Math.round(agencyFeeUSD * settlementRate);
                
                const marginKRW = sellingPriceKRW - costPriceKRW - outHotelCostKRW;
                const tax = Math.round(marginKRW * 0.1);

                // 합계 누적
                totalSellingUSD += sellingPriceUSD;
                totalSellingKRW += sellingPriceKRW;
                totalCostUSD += costPriceUSD;
                totalCostKRW += costPriceKRW;
                totalOutHotelUSD += outHotelCostUSD;
                totalOutHotelKRW += outHotelCostKRW;
                totalAgencyFeeUSD += agencyFeeUSD;
                totalAgencyFeeKRW += agencyFeeKRW;
                totalMarginKRW += marginKRW;
                totalTax += tax;
                
                // 미완료 탭 통계 계산 (거래액 기준)
                if (currentTab === 'incomplete') {
                    const hasReceived = !!s.payment_received_date;
                    const hasSent = !!s.payment_sent_date;
                    
                    if (hasReceived && !hasSent) {
                        // 입금완료, 송금미완료
                        receivedOnlyTotal += sellingPriceKRW;
                        receivedOnlyCount++;
                    } else if (!hasReceived && hasSent) {
                        // 송금완료, 입금미완료
                        sentOnlyTotal += sellingPriceKRW;
                        sentOnlyCount++;
                    }
                }

                const checkInDate = s.check_in_date ? new Date(s.check_in_date).toLocaleDateString('ko-KR') : '-';
                const paymentReceivedDate = s.payment_received_date ? new Date(s.payment_received_date).toLocaleDateString('ko-KR') : '-';
