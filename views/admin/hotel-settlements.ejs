                document.getElementById('receivedOnlyTotal').textContent = '₩' + Math.round(receivedOnlyTotal).toLocaleString();
                document.getElementById('receivedOnlyCount').textContent = receivedOnlyCount + '건';
                document.getElementById('sentOnlyTotal').textContent = '₩' + Math.round(sentOnlyTotal).toLocaleString();
