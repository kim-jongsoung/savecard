<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>패키지 정산관리 - 괌세이브카드 관리자</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .editable-cell {
            cursor: pointer;
            border: 1px solid transparent;
            padding: 4px 8px;
            border-radius: 3px;
        }
        .editable-cell:hover {
            background-color: #f0f8ff;
            border-color: #007bff;
        }
        .editable-cell.editing {
            background-color: #fff3cd;
            border-color: #ffc107;
        }
        .cost-input {
            width: 120px;
            text-align: right;
        }
        .vendor-row {
            background-color: #f8f9fa;
        }
        .vendor-row:hover {
            background-color: #e9ecef;
        }
        .sent-row {
            background-color: #d4edda;
        }
        .pending-row {
            background-color: #fff3cd;
        }
        
        /* 정산서 인쇄 스타일 */
        @media print {
            @page {
                size: A4;
                margin: 8mm;
            }
            
            body * {
                visibility: hidden;
            }
            #settlementDocument, #settlementDocument * {
                visibility: visible;
            }
            #settlementDocument {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
            }
            .no-print {
                display: none !important;
            }
            
            .settlement-document {
                padding: 0 !important;
                max-width: 100% !important;
            }
            
            .doc-header {
                padding-bottom: 4px !important;
                margin-bottom: 6px !important;
                border-bottom: 1px solid #000 !important;
            }
            
            .doc-title {
                font-size: 16px !important;
                margin-bottom: 2px !important;
                line-height: 1.2 !important;
            }
            
            .doc-number {
                font-size: 8px !important;
                line-height: 1.2 !important;
            }
            
            .doc-section {
                margin-bottom: 6px !important;
            }
            
            .doc-section-title {
                font-size: 11px !important;
                padding: 2px 4px !important;
                margin-bottom: 3px !important;
                border-left: 2px solid #000 !important;
                background-color: #f0f0f0 !important;
                line-height: 1.2 !important;
            }
            
            .doc-table {
                margin-bottom: 4px !important;
                font-size: 8px !important;
            }
            
            .doc-table th,
            .doc-table td {
                padding: 1px 2px !important;
                border: 1px solid #000 !important;
                line-height: 1.1 !important;
            }
            
            .doc-table th {
                background-color: #e9ecef !important;
            }
            
            .doc-summary {
                background-color: #f0f0f0 !important;
                border: 1px solid #000 !important;
                padding: 4px !important;
                margin-top: 6px !important;
            }
            
            .doc-summary-title {
                font-size: 11px !important;
                margin-bottom: 3px !important;
                line-height: 1.2 !important;
            }
            
            .doc-summary .doc-table {
                font-size: 8px !important;
            }
            
            .doc-footer {
                margin-top: 6px !important;
                font-size: 8px !important;
                line-height: 1.2 !important;
            }
            
            .doc-footer p {
                margin-bottom: 2px !important;
            }
            
            * {
                color: #000 !important;
                background-color: transparent !important;
            }
            
            .doc-table th {
                background-color: #e9ecef !important;
            }
            
            .doc-section-title {
                background-color: #f0f0f0 !important;
            }
            
            .doc-summary {
                background-color: #f0f0f0 !important;
            }
        }
        
        .settlement-document {
            background: white;
            padding: 20px;
            max-width: 210mm;
            margin: 0 auto;
        }
        
        .doc-header {
            text-align: center;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }
        
        .doc-title {
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .doc-number {
            font-size: 11px;
            color: #666;
        }
        
        .doc-section {
            margin-bottom: 15px;
        }
        
        .doc-section-title {
            font-size: 14px;
            font-weight: bold;
            background-color: #f0f0f0;
            padding: 5px 8px;
            border-left: 3px solid #007bff;
            margin-bottom: 8px;
        }
        
        .doc-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
            font-size: 11px;
        }
        
        .doc-table th,
        .doc-table td {
            border: 1px solid #000;
            padding: 4px 6px;
            text-align: left;
        }
        
        .doc-table th {
            background-color: #e9ecef;
            font-weight: bold;
        }
        
        .doc-table td.text-end {
            text-align: right;
        }
        
        .doc-summary {
            background-color: #f0f0f0;
            border: 2px solid #000;
            padding: 10px;
            margin-top: 15px;
        }
        
        .doc-summary-title {
            font-size: 15px;
            font-weight: bold;
            margin-bottom: 8px;
            text-align: center;
        }
        
        .doc-footer {
            margin-top: 15px;
            text-align: right;
            font-size: 11px;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { currentPage: 'package-settlements', adminUsername: adminName || '관리자' }) %>

    <div class="container-fluid mt-4">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2><i class="fas fa-calculator me-2"></i>패키지 정산관리</h2>
                    <a href="/admin/package-reservations" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left me-1"></i>예약관리로 돌아가기
                    </a>
                </div>
            </div>
        </div>

        <!-- 검색 필터 -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label class="form-label">출발일 (시작)</label>
                        <input type="date" class="form-control" id="filter_start_date">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">출발일 (종료)</label>
                        <input type="date" class="form-control" id="filter_end_date">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">예약채널</label>
                        <select class="form-select" id="filter_platform">
                            <option value="">전체</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">송금상태</label>
                        <select class="form-select" id="filter_status">
                            <option value="all">전체</option>
                            <option value="pending">미송금</option>
                            <option value="partial">부분송금</option>
                            <option value="completed">송금완료</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">검색</label>
                        <input type="text" class="form-control" id="filter_search" placeholder="예약번호, 고객명">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">매입처 / 구성요소</label>
                        <input type="text" class="form-control" id="filter_vendor" placeholder="매입처명, 항공권...">
                    </div>
                    <div class="col-md-2 d-flex align-items-end gap-2">
                        <button class="btn btn-primary flex-grow-1" onclick="filterAndRender()">
                            <i class="fas fa-search me-1"></i>검색
                        </button>
                        <button class="btn btn-outline-secondary" onclick="resetFilters()" title="필터 초기화">
                            <i class="fas fa-undo"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 통계 영역 -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body">
                        <h6><i class="fas fa-clock me-2"></i>송금전</h6>
                        <h3 id="stat_pending_count">0</h3>
                        <small>입금완료, 송금대기</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h6><i class="fas fa-check-circle me-2"></i>송금완료</h6>
                        <h3 id="stat_completed_count">0</h3>
                        <small>정산완료</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h6><i class="fas fa-money-bill-wave me-2"></i>미송금 총액</h6>
                        <h3 id="stat_pending_amount">₩0</h3>
                        <small>송금해야 할 금액</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h6><i class="fas fa-paper-plane me-2"></i>송금완료 총액</h6>
                        <h3 id="stat_completed_amount">₩0</h3>
                        <small>이번 달 송금액</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- 탭 네비게이션 -->
        <ul class="nav nav-tabs mb-3" id="settlementTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" onclick="currentTab='pending'; filterAndRender();">
                    <i class="fas fa-clock me-2"></i>송금전 (<span id="pending_count">0</span>)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completed" type="button" onclick="currentTab='completed'; filterAndRender();">
                    <i class="fas fa-check-circle me-2"></i>송금완료 (<span id="completed_count">0</span>)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="status-tab" data-bs-toggle="tab" data-bs-target="#statusPanel" type="button" onclick="currentTab='status'; loadSettlementStatus();">
                    <i class="fas fa-chart-bar me-2"></i>정산현황
                </button>
            </li>
        </ul>

        <!-- 일괄 처리 버튼 -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="me-3">선택: <strong id="selected_count">0</strong>건</span>
                        <span class="me-3">총 매입액: <strong id="selected_total">₩0</strong></span>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        <!-- 일괄선택 드롭다운 -->
                        <div class="dropdown">
                            <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-check-square me-1"></i>일괄선택
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#" onclick="selectByVendorFilter(); return false;">
                                    <i class="fas fa-filter me-2 text-primary"></i>현재 검색결과 전체선택
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#" onclick="selectByType('flight'); return false;">
                                    <i class="me-2">✈️</i>항공권 전체선택
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="selectByType('hotel'); return false;">
                                    <i class="me-2">🏨</i>호텔 전체선택
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="selectByType('tour'); return false;">
                                    <i class="me-2">🎯</i>투어 전체선택
                                </a></li>
                                <li><a class="dropdown-item" href="#" onclick="selectByType('ground'); return false;">
                                    <i class="me-2">🚗</i>지상교통 전체선택
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#" onclick="selectAllVisible(); return false;">
                                    <i class="fas fa-check-double me-2 text-success"></i>화면 전체선택
                                </a></li>
                            </ul>
                        </div>
                        <button class="btn btn-success" onclick="bulkSendPayment()">
                            <i class="fas fa-paper-plane me-1"></i>선택 항목 일괄 송금완료
                        </button>
                        <button class="btn btn-outline-secondary" onclick="clearSelection()">
                            <i class="fas fa-times me-1"></i>선택 해제
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 탭 컨텐츠 -->
        <div class="tab-content" id="settlementTabContent">
            <div class="tab-pane fade show active" id="pending" role="tabpanel">
                <div id="pending_list">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">로딩 중...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="completed" role="tabpanel">
                <div id="completed_list">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">로딩 중...</span>
                        </div>
                    </div>
                </div>
            </div>
        <!-- 필터 결과 매입액 합계 바 -->
        <div class="card border-0 shadow-sm mt-3" id="filteredSummaryBar" style="display:none">
            <div class="card-body py-2 px-4 bg-dark text-white rounded">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-4">
                        <span style="font-size:.9rem"><i class="fas fa-filter me-1 text-warning"></i>검색결과 <strong id="filteredCount">0</strong>건</span>
                        <span style="font-size:.9rem">총 매입액 합계: <strong id="filteredTotalCost" class="text-warning fs-6">₩0</strong></span>
                        <span style="font-size:.9rem">미송금액: <strong id="filteredPendingCost" class="text-danger">₩0</strong></span>
                        <span style="font-size:.9rem">송금완료액: <strong id="filteredSentCost" class="text-success">₩0</strong></span>
                    </div>
                </div>
            </div>
        </div>

            <!-- 정산현황 탭 패널 -->
            <div class="tab-pane fade" id="statusPanel" role="tabpanel">
                <!-- 요약 카드 -->
                <div class="row g-3 mb-3" id="statusSummary">
                    <div class="col-6 col-md-3">
                        <div class="card border-success">
                            <div class="card-body py-2 px-3">
                                <div class="small text-muted">수탁액 <span class="badge bg-success ms-1">출발전 입금</span></div>
                                <div class="fw-bold fs-6 text-success" id="sum_deposit">-</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-danger">
                            <div class="card-body py-2 px-3">
                                <div class="small text-muted">미수금 <span class="badge bg-danger ms-1">출발후 미입금</span></div>
                                <div class="fw-bold fs-6 text-danger" id="sum_receivable">-</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-primary">
                            <div class="card-body py-2 px-3">
                                <div class="small text-muted">선급금 <span class="badge bg-primary ms-1">출발전 송금</span></div>
                                <div class="fw-bold fs-6 text-primary" id="sum_prepaid">-</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-warning">
                            <div class="card-body py-2 px-3">
                                <div class="small text-muted">미지급금 <span class="badge bg-warning text-dark ms-1">출발후 미송금</span></div>
                                <div class="fw-bold fs-6 text-warning" id="sum_payable">-</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 테이블 -->
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size:.82rem">
                        <thead class="table-dark">
                            <tr>
                                <th>출발일</th>
                                <th>예약번호</th>
                                <th>채널</th>
                                <th>고객명</th>
                                <th class="text-end">판매금액</th>
                                <th class="text-end">입금액</th>
                                <th class="text-end text-success">수탁액</th>
                                <th class="text-end text-danger">미수금</th>
                                <th class="text-end">매입총액</th>
                                <th class="text-end">송금액</th>
                                <th class="text-end text-primary">선급금</th>
                                <th class="text-end text-warning">미지급금</th>
                                <th class="text-end">손익</th>
                                <th>상태</th>
                            </tr>
                        </thead>
                        <tbody id="statusTableBody">
                            <tr><td colspan="14" class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- 정산서 미리보기 모달 -->
    <div class="modal fade" id="settlementDocumentModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header no-print">
                    <h5 class="modal-title"><i class="fas fa-file-invoice me-2"></i>정산서</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="settlementDocument">
                    <!-- 정산서 내용이 동적으로 생성됩니다 -->
                </div>
                <div class="modal-footer no-print">
                    <button type="button" class="btn btn-primary" onclick="printSettlement()">
                        <i class="fas fa-print me-1"></i>인쇄
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>닫기
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let allReservations = [];
        let selectedItems = new Set();
        let currentTab = 'pending';

        // 정산 목록 로드
        async function loadSettlements() {
            try {
                const response = await fetch('/api/package-settlements/list');
                const result = await response.json();
                
                if (!result.success) {
                    alert('정산 목록을 불러오는데 실패했습니다.');
                    return;
                }
                
                const { pending, completed, stats } = result.data;
                
                // 통계 업데이트
                document.getElementById('stat_pending_count').textContent = stats.pending_count;
                document.getElementById('stat_completed_count').textContent = stats.completed_count;
                document.getElementById('stat_pending_amount').textContent = `₩${stats.pending_amount.toLocaleString()}`;
                document.getElementById('stat_completed_amount').textContent = `₩${stats.completed_amount.toLocaleString()}`;
                
                document.getElementById('pending_count').textContent = pending.length;
                document.getElementById('completed_count').textContent = completed.length;
                
                // 예약 데이터 저장
                allReservations = { pending, completed };
                
                // 채널 필터 옵션 업데이트
                updatePlatformFilter();
                
                // 필터 적용 및 렌더링
                filterAndRender();
                
            } catch (error) {
                console.error('정산 목록 로드 실패:', error);
                alert('정산 목록을 불러오는 중 오류가 발생했습니다.');
            }
        }

        // 채널 필터 옵션 업데이트
        function updatePlatformFilter() {
            const allItems = [...allReservations.pending, ...allReservations.completed];
            const platforms = [...new Set(allItems.map(r => r.platform_name))];
            const select = document.getElementById('filter_platform');
            select.innerHTML = '<option value="">전체</option>' + 
                platforms.map(p => `<option value="${p}">${p}</option>`).join('');
        }

        // 필터 초기화
        function resetFilters() {
            document.getElementById('filter_start_date').value = '';
            document.getElementById('filter_end_date').value = '';
            document.getElementById('filter_platform').value = '';
            document.getElementById('filter_status').value = 'all';
            document.getElementById('filter_search').value = '';
            document.getElementById('filter_vendor').value = '';
            filterAndRender();
        }

        // 필터링 및 렌더링
        function filterAndRender() {
            const startDate = document.getElementById('filter_start_date').value;
            const endDate = document.getElementById('filter_end_date').value;
            const platform = document.getElementById('filter_platform').value;
            const search = document.getElementById('filter_search').value.toLowerCase().trim();
            const vendorSearch = document.getElementById('filter_vendor').value.toLowerCase().trim();

            // 현재 탭에 따라 데이터 선택
            const items = currentTab === 'pending' ? allReservations.pending : allReservations.completed;

            let filtered = items.filter(reservation => {
                // 날짜 필터
                if (startDate && new Date(reservation.travel_period.departure_date) < new Date(startDate)) return false;
                if (endDate && new Date(reservation.travel_period.departure_date) > new Date(endDate)) return false;
                
                // 쉡널 필터
                if (platform && reservation.platform_name !== platform) return false;
                
                // 예약번호/고객명 검색
                if (search && !reservation.reservation_number.toLowerCase().includes(search) && 
                    !reservation.customer.korean_name.toLowerCase().includes(search)) return false;
                
                // 매입처/구성요소 검색 - 해당 예약에 일치하는 매입처가 하나라도 있으면 포함
                if (vendorSearch) {
                    const components = reservation.cost_components || [];
                    const typeNames = { flight: '항공권', hotel: '호텔', tour: '투어', ground: '지상교통' };
                    const hasMatch = components.some(c =>
                        (c.vendor_name || '').toLowerCase().includes(vendorSearch) ||
                        (c.component_type || '').toLowerCase().includes(vendorSearch) ||
                        (typeNames[c.component_type] || '').includes(vendorSearch)
                    );
                    if (!hasMatch) return false;
                }
                
                return true;
            });

            renderReservations(filtered, vendorSearch);
        }

        // 예약 목록 렌더링 (예약별 그룹화)
        function renderReservations(reservations, vendorSearch = '') {
            const container = currentTab === 'pending' ? document.getElementById('pending_list') : document.getElementById('completed_list');
            
            if (reservations.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-5">검색 결과가 없습니다.</div>';
                return;
            }

            container.innerHTML = reservations.map(reservation => {
                const components = reservation.cost_components || [];
                const totalCost = components.reduce((sum, c) => sum + (c.cost_krw || 0), 0);
                const sentCount = components.filter(c => c.payment_sent_date).length;
                
                return `
                    <div class="card mb-3">
                        <div class="card-header bg-light">
                            <div class="row align-items-center">
                                <div class="col-md-2">
                                    <strong>출발일:</strong> ${new Date(reservation.travel_period.departure_date).toLocaleDateString('ko-KR')}
                                </div>
                                <div class="col-md-2">
                                    <strong>채널:</strong> ${reservation.platform_name}
                                </div>
                                <div class="col-md-2">
                                    <strong>예약번호:</strong> ${reservation.reservation_number}
                                </div>
                                <div class="col-md-2">
                                    <strong>고객명:</strong> ${reservation.customer.korean_name}
                                </div>
                                <div class="col-md-2">
                                    <strong>총 매입액:</strong> <span class="text-primary">₩${totalCost.toLocaleString()}</span>
                                </div>
                                <div class="col-md-2 text-end">
                                    <span class="badge ${sentCount === components.length ? 'bg-success' : sentCount > 0 ? 'bg-warning' : 'bg-secondary'}">
                                        ${sentCount}/${components.length} 송금완료
                                    </span>
                                    ${currentTab === 'completed' && sentCount === components.length ? `
                                        <button class="btn btn-sm btn-outline-primary ms-2" onclick="openSettlementDocument('${reservation._id}')">
                                            <i class="fas fa-file-invoice me-1"></i>정산서
                                        </button>
                                    ` : ''}
                                </div>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 40px;">
                                            <input type="checkbox" onchange="toggleReservationAll('${reservation._id}', this.checked)">
                                        </th>
                                        <th>매입처</th>
                                        <th>구성요소</th>
                                        <th>매입액</th>
                                        <th>송금일</th>
                                        <th>상태</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${components.map((comp, idx) => {
                                        const itemKey = `${reservation._id}_${idx}`;
                                        const isSelected = selectedItems.has(itemKey);
                                        const isSent = !!comp.payment_sent_date;
                                        
                                        const typeIcon = comp.component_type === 'flight' ? '✈️' : 
                                                       comp.component_type === 'hotel' ? '🏨' : 
                                                       comp.component_type === 'tour' ? '🎯' : 
                                                       comp.component_type === 'ground' ? '🚗' : '📦';
                                        const typeName = comp.component_type === 'flight' ? '항공권' : 
                                                       comp.component_type === 'hotel' ? '호텔' : 
                                                       comp.component_type === 'tour' ? '투어' : 
                                                       comp.component_type === 'ground' ? '지상' : '기타';

                                        // 매입처 검색 하이라이트 및 숨김
                                        const isVendorMatch = vendorSearch && (
                                            (comp.vendor_name || '').toLowerCase().includes(vendorSearch) ||
                                            (comp.component_type || '').toLowerCase().includes(vendorSearch) ||
                                            typeName.includes(vendorSearch)
                                        );
                                        // 검색어 있을 때 불일치 행 숨김
                                        if (vendorSearch && !isVendorMatch) return '';
                                        const rowClass = isVendorMatch ? 'table-info' : (isSent ? 'sent-row' : 'pending-row');

                                        return `
                                            <tr class="${rowClass}" ${isVendorMatch ? 'style="outline: 2px solid #0d6efd;"' : ''}>
                                                <td class="text-center">
                                                    <input type="checkbox" 
                                                           class="vendor-checkbox"
                                                           data-reservation-id="${reservation._id}"
                                                           data-item-key="${itemKey}"
                                                           ${isSent ? 'disabled' : ''}
                                                           ${isSelected ? 'checked' : ''}
                                                           onchange="toggleItemSelection('${itemKey}')">
                                                </td>
                                                <td><strong>${comp.vendor_name}</strong></td>
                                                <td>${typeIcon} ${typeName}</td>
                                                <td>
                                                    <div class="editable-cell" 
                                                         onclick="editCost('${itemKey}', ${comp.cost_krw || 0})"
                                                         id="cost_${itemKey}">
                                                        ₩${(comp.cost_krw || 0).toLocaleString()}
                                                    </div>
                                                </td>
                                                <td>
                                                    <input type="date" 
                                                           class="form-control form-control-sm" 
                                                           value="${comp.payment_sent_date ? new Date(comp.payment_sent_date).toISOString().split('T')[0] : ''}"
                                                           onchange="updateSentDate('${itemKey}', this.value, ${isSent})">
                                                </td>
                                                <td>
                                                    ${isSent 
                                                        ? `<span class="badge bg-success">송금완료</span>
                                                           <button class="btn btn-xs btn-outline-danger ms-1" style="font-size:11px;padding:1px 5px;" onclick="cancelPayment('${itemKey}')">
                                                               <i class="fas fa-undo"></i> 취소
                                                           </button>` 
                                                        : '<span class="badge bg-warning">미송금</span>'}
                                                </td>
                                            </tr>
                                        `;
                                    }).join('')}
                                </tbody>
                            </table>
                        </div>
                    </div>
                `;
            }).join('');

            updateSelectionInfo();
            updateFilteredSummary(reservations);
        }

        // 필터 결과 합계 바 업데이트
        function updateFilteredSummary(reservations) {
            const bar = document.getElementById('filteredSummaryBar');
            if (!reservations || reservations.length === 0) {
                bar.style.display = 'none';
                return;
            }
            let totalCost = 0, sentCost = 0, pendingCost = 0;
            reservations.forEach(r => {
                (r.cost_components || []).forEach(c => {
                    const amt = c.cost_krw || 0;
                    totalCost += amt;
                    if (c.payment_sent_date) sentCost += amt;
                    else pendingCost += amt;
                });
            });
            document.getElementById('filteredCount').textContent = reservations.length;
            document.getElementById('filteredTotalCost').textContent = '₩' + totalCost.toLocaleString();
            document.getElementById('filteredPendingCost').textContent = '₩' + pendingCost.toLocaleString();
            document.getElementById('filteredSentCost').textContent = '₩' + sentCost.toLocaleString();
            bar.style.display = 'block';
        }

        // 예약 전체 선택/해제
        function toggleReservationAll(reservationId, checked) {
            document.querySelectorAll(`input.vendor-checkbox[data-reservation-id="${reservationId}"]:not([disabled])`).forEach(checkbox => {
                checkbox.checked = checked;
                const itemKey = checkbox.dataset.itemKey;
                if (checked) {
                    selectedItems.add(itemKey);
                } else {
                    selectedItems.delete(itemKey);
                }
            });
            updateSelectionInfo();
        }

        // 매입액 인라인 편집
        function editCost(itemKey, currentCost) {
            const cell = document.getElementById(`cost_${itemKey}`);
            const [reservationId, componentIndex] = itemKey.split('_');
            
            // 송금 완료 여부 확인 - 완료된 건도 수정 허용 (이력 기록)
            const allItems = [...allReservations.pending, ...allReservations.completed];
            const reservation = allItems.find(r => r._id === reservationId);
            const isSentItem = reservation && reservation.cost_components[parseInt(componentIndex)].payment_sent_date;
            if (isSentItem) {
                const reason = prompt('⚠️ 송금완료된 항목입니다.\n금액 변경 사유를 입력하세요:');
                if (!reason || !reason.trim()) {
                    alert('수정 사유를 입력해야 합니다.');
                    return;
                }
                cell.dataset.changeReason = reason.trim();
                cell.dataset.originalCost = currentCost;
            }

            cell.classList.add('editing');
            cell.innerHTML = `
                <input type="number" 
                       class="form-control form-control-sm cost-input" 
                       value="${currentCost}" 
                       id="input_${itemKey}"
                       onblur="saveCost('${itemKey}')"
                       onkeypress="if(event.key==='Enter') saveCost('${itemKey}')">
            `;
            document.getElementById(`input_${itemKey}`).focus();
        }

        // 변경이력 추가 헬퍼
        function addChangeLog(component, type, before, after, reason) {
            if (!component.change_logs) component.change_logs = [];
            component.change_logs.push({
                type,           // 'cost' | 'date' | 'cancel'
                before: String(before),
                after: String(after),
                reason,
                changed_at: new Date().toISOString()
            });
        }

        // 매입액 저장
        async function saveCost(itemKey) {
            const input = document.getElementById(`input_${itemKey}`);
            const newCost = parseInt(input.value) || 0;
            const cell = document.getElementById(`cost_${itemKey}`);
            const changeReason = cell?.dataset.changeReason || null;
            const originalCost = parseInt(cell?.dataset.originalCost) || null;
            const [reservationId, componentIndex] = itemKey.split('_');

            try {
                const response = await fetch(`/api/package-reservations/${reservationId}`);
                const result = await response.json();
                
                if (!result.success) {
                    alert('예약 정보를 불러오는데 실패했습니다.');
                    return;
                }

                const reservation = result.data;
                const comp = reservation.cost_components[parseInt(componentIndex)];
                const prevCost = originalCost ?? comp.cost_krw ?? 0;

                // 이력 기록 (사유가 있을 때 = 송금완료 건 수정)
                if (changeReason) {
                    addChangeLog(comp, 'cost', `₩${prevCost.toLocaleString()}`, `₩${newCost.toLocaleString()}`, changeReason);
                }

                comp.cost_krw = newCost;

                // 총 매입액 재계산
                const totalCost = reservation.cost_components.reduce((sum, c) => sum + (c.cost_krw || 0), 0);
                reservation.settlement.total_cost_krw = totalCost;

                const updateResponse = await fetch(`/api/package-reservations/${reservationId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        cost_components: reservation.cost_components,
                        settlement: reservation.settlement
                    })
                });

                const updateResult = await updateResponse.json();
                
                if (updateResult.success) {
                    if (changeReason) alert(`✅ 금액이 수정되었습니다.\n변경이력이 기록되었습니다.`);
                    else alert('매입액이 수정되었습니다.');
                    loadSettlements();
                } else {
                    alert('매입액 수정에 실패했습니다.');
                    loadSettlements();
                }
            } catch (error) {
                console.error('매입액 수정 실패:', error);
                alert('매입액 수정 중 오류가 발생했습니다.');
                loadSettlements();
            }
        }

        // 송금일 업데이트
        async function updateSentDate(itemKey, date, isSentAlready) {
            const [reservationId, componentIndex] = itemKey.split('_');

            let reason = null;
            if (isSentAlready && date) {
                reason = prompt('⚠️ 송금완료된 항목의 날짜를 변경합니다.\n변경 사유를 입력하세요:');
                if (!reason || !reason.trim()) {
                    alert('수정 사유를 입력해야 합니다.');
                    loadSettlements();
                    return;
                }
                reason = reason.trim();
            }

            try {
                const response = await fetch(`/api/package-reservations/${reservationId}`);
                const result = await response.json();
                
                if (!result.success) {
                    alert('예약 정보를 불러오는데 실패했습니다.');
                    return;
                }

                const reservation = result.data;
                const comp = reservation.cost_components[parseInt(componentIndex)];
                const prevDate = comp.payment_sent_date ? new Date(comp.payment_sent_date).toLocaleDateString('ko-KR') : '없음';

                // 이력 기록
                if (reason) {
                    addChangeLog(comp, 'date', prevDate, date ? new Date(date).toLocaleDateString('ko-KR') : '없음', reason);
                }

                comp.payment_sent_date = date || null;

                const updateResponse = await fetch(`/api/package-reservations/${reservationId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cost_components: reservation.cost_components })
                });

                const updateResult = await updateResponse.json();
                
                if (updateResult.success) {
                    if (reason) alert('✅ 송금일이 수정되었습니다.\n변경이력이 기록되었습니다.');
                    loadSettlements();
                } else {
                    alert('송금일 업데이트에 실패했습니다.');
                }
            } catch (error) {
                console.error('송금일 업데이트 실패:', error);
                alert('송금일 업데이트 중 오류가 발생했습니다.');
            }
        }

        // 송금 취소 (송금전으로 복귀)
        async function cancelPayment(itemKey) {
            const [reservationId, componentIndex] = itemKey.split('_');
            const allItems = [...allReservations.pending, ...allReservations.completed];
            const reservation = allItems.find(r => r._id === reservationId);
            const comp = reservation?.cost_components[parseInt(componentIndex)];
            const vendorName = comp?.vendor_name || '해당 항목';

            const reason = prompt(`⚠️ [${vendorName}] 송금을 취소하고 송금전으로 되돌립니다.\n취소 사유를 입력하세요:`);
            if (!reason || !reason.trim()) {
                alert('취소 사유를 입력해야 합니다.');
                return;
            }

            if (!confirm(`[${vendorName}] 송금취소 처리하시겠습니까?\n사유: ${reason.trim()}`)) return;

            try {
                const response = await fetch(`/api/package-reservations/${reservationId}`);
                const result = await response.json();
                if (!result.success) { alert('예약 정보를 불러오는데 실패했습니다.'); return; }

                const resData = result.data;
                const targetComp = resData.cost_components[parseInt(componentIndex)];
                const prevDate = targetComp.payment_sent_date ? new Date(targetComp.payment_sent_date).toLocaleDateString('ko-KR') : '없음';

                // 이력 기록
                addChangeLog(targetComp, 'cancel', prevDate, '취소', reason.trim());

                // 송금일 초기화
                targetComp.payment_sent_date = null;

                const updateResponse = await fetch(`/api/package-reservations/${reservationId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cost_components: resData.cost_components })
                });

                const updateResult = await updateResponse.json();
                if (updateResult.success) {
                    alert(`✅ 송금취소 완료\n[${vendorName}]이 송금전 탭으로 이동되었습니다.\n취소이력이 기록되었습니다.`);
                    loadSettlements();
                } else {
                    alert('송금취소 처리에 실패했습니다.');
                }
            } catch (error) {
                console.error('송금취소 실패:', error);
                alert('송금취소 중 오류가 발생했습니다.');
            }
        }

        // 현재 검색결과(필터_vendor 기준) 전체선택
        function selectByVendorFilter() {
            const vendorSearch = document.getElementById('filter_vendor').value.toLowerCase().trim();
            document.querySelectorAll('input.vendor-checkbox:not([disabled])').forEach(cb => {
                const itemKey = cb.dataset.itemKey;
                const [reservationId, idx] = itemKey.split('_');
                const allItems = [...allReservations.pending, ...allReservations.completed];
                const reservation = allItems.find(r => r._id === reservationId);
                if (!reservation) return;
                const comp = reservation.cost_components[parseInt(idx)];
                if (!comp) return;
                const typeNames = { flight: '항공권', hotel: '호텔', tour: '투어', ground: '지상교통' };
                const typeName = typeNames[comp.component_type] || '';
                const matches = !vendorSearch || (
                    (comp.vendor_name || '').toLowerCase().includes(vendorSearch) ||
                    (comp.component_type || '').toLowerCase().includes(vendorSearch) ||
                    typeName.includes(vendorSearch)
                );
                if (matches) {
                    cb.checked = true;
                    selectedItems.add(itemKey);
                }
            });
            updateSelectionInfo();
        }

        // 구성요소 타입별 전체선택
        function selectByType(type) {
            const allItems = [...allReservations.pending, ...allReservations.completed];
            document.querySelectorAll('input.vendor-checkbox:not([disabled])').forEach(cb => {
                const itemKey = cb.dataset.itemKey;
                const [reservationId, idx] = itemKey.split('_');
                const reservation = allItems.find(r => r._id === reservationId);
                if (!reservation) return;
                const comp = reservation.cost_components[parseInt(idx)];
                if (comp && comp.component_type === type) {
                    cb.checked = true;
                    selectedItems.add(itemKey);
                }
            });
            updateSelectionInfo();
        }

        // 화면에 보이는 체크박스 전체선택
        function selectAllVisible() {
            document.querySelectorAll('input.vendor-checkbox:not([disabled])').forEach(cb => {
                cb.checked = true;
                selectedItems.add(cb.dataset.itemKey);
            });
            updateSelectionInfo();
        }

        // 항목 선택/해제
        function toggleItemSelection(itemKey) {
            if (selectedItems.has(itemKey)) {
                selectedItems.delete(itemKey);
            } else {
                selectedItems.add(itemKey);
            }
            updateSelectionInfo();
        }

        // 전체 선택/해제 (사용 안 함 - 예약별 체크박스 사용)
        function toggleSelectAll(checked) {
            // 사용 안 함
        }

        // 선택 해제
        function clearSelection() {
            selectedItems.clear();
            document.querySelectorAll('input[data-item-key]').forEach(checkbox => {
                checkbox.checked = false;
            });
            document.getElementById('select_all').checked = false;
            updateSelectionInfo();
        }

        // 선택 정보 업데이트
        function updateSelectionInfo() {
            const count = selectedItems.size;
            let total = 0;
            
            const allItems = [...allReservations.pending, ...allReservations.completed];
            selectedItems.forEach(itemKey => {
                const [reservationId, componentIndex] = itemKey.split('_');
                const reservation = allItems.find(r => r._id === reservationId);
                if (reservation && reservation.cost_components[parseInt(componentIndex)]) {
                    total += reservation.cost_components[parseInt(componentIndex)].cost_krw || 0;
                }
            });

            document.getElementById('selected_count').textContent = count;
            document.getElementById('selected_total').textContent = `₩${total.toLocaleString()}`;
        }

        // 일괄 송금 처리
        async function bulkSendPayment() {
            if (selectedItems.size === 0) {
                alert('송금 처리할 항목을 선택해주세요.');
                return;
            }

            const today = new Date().toISOString().split('T')[0];
            const sentDate = prompt('송금일을 입력하세요 (YYYY-MM-DD):', today);
            
            if (!sentDate) return;
            
            if (!confirm(`선택한 ${selectedItems.size}개 항목을 송금 완료 처리하시겠습니까?`)) return;

            try {
                // 예약별로 그룹화
                const reservationGroups = {};
                selectedItems.forEach(itemKey => {
                    const [reservationId, componentIndex] = itemKey.split('_');
                    if (!reservationGroups[reservationId]) {
                        reservationGroups[reservationId] = [];
                    }
                    reservationGroups[reservationId].push(parseInt(componentIndex));
                });

                // 각 예약별로 업데이트
                let failCount = 0;
                for (const [reservationId, indices] of Object.entries(reservationGroups)) {
                    const getRes = await fetch(`/api/package-reservations/${reservationId}`);
                    const getResult = await getRes.json();

                    if (!getResult.success) { failCount++; continue; }

                    const reservation = getResult.data;
                    indices.forEach(index => {
                        if (reservation.cost_components[index]) {
                            reservation.cost_components[index].payment_sent_date = sentDate;
                        }
                    });

                    const putRes = await fetch(`/api/package-reservations/${reservationId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ cost_components: reservation.cost_components })
                    });
                    const putResult = await putRes.json();
                    if (!putResult.success) failCount++;
                }

                if (failCount > 0) {
                    alert(`${failCount}건 처리 실패. 나머지는 완료됐습니다.`);
                } else {
                    alert('일괄 송금 처리가 완료되었습니다.');
                }
                clearSelection();
                loadSettlements();

            } catch (error) {
                console.error('일괄 송금 처리 실패:', error);
                alert('송금 처리 오류: ' + error.message);
            }
        }

        // 정산서 열기
        async function openSettlementDocument(reservationId) {
            try {
                const response = await fetch(`/api/package-reservations/${reservationId}`);
                const result = await response.json();
                
                if (!result.success) {
                    alert('예약 정보를 불러오는데 실패했습니다.');
                    return;
                }
                
                const r = result.data;
                
                // 입금 내역 계산
                const billings = r.billings || [];
                const completedBillings = billings.filter(b => b.status === 'completed');
                const totalReceived = completedBillings.reduce((sum, b) => sum + (b.amount || 0), 0);
                
                // 매입 내역 계산
                const components = r.cost_components || [];
                const totalCost = components.reduce((sum, c) => sum + (c.cost_krw || 0), 0);
                
                // 수익 계산
                const profit = totalReceived - totalCost;
                
                // 부가세 계산 (수익의 10%)
                const vat = Math.round(profit * 0.1);
                
                // 순수익 (수익 - 부가세)
                const netProfit = profit - vat;
                
                // 정산서 HTML 생성
                const documentHtml = `
                    <div class="settlement-document">
                        <div class="doc-header">
                            <div class="doc-title">패키지 여행 정산서</div>
                            <div class="doc-number">문서번호: PKG-${r.reservation_number}-${new Date().getFullYear()}</div>
                            <div class="doc-number">발행일자: ${new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
                        </div>
                        
                        <!-- 기본 정보 -->
                        <div class="doc-section">
                            <div class="doc-section-title">1. 예약 기본 정보</div>
                            <table class="doc-table">
                                <tr>
                                    <th style="width: 150px;">예약번호</th>
                                    <td>${r.reservation_number}</td>
                                    <th style="width: 150px;">예약채널</th>
                                    <td>${r.platform_name}</td>
                                </tr>
                                <tr>
                                    <th>고객명</th>
                                    <td>${r.customer.korean_name}</td>
                                    <th>연락처</th>
                                    <td>${r.customer.phone || '-'}</td>
                                </tr>
                                <tr>
                                    <th>출발일</th>
                                    <td>${new Date(r.travel_period.departure_date).toLocaleDateString('ko-KR')}</td>
                                    <th>귀국일</th>
                                    <td>${new Date(r.travel_period.return_date).toLocaleDateString('ko-KR')}</td>
                                </tr>
                                <tr>
                                    <th>여행인원</th>
                                    <td colspan="3">성인 ${r.traveler_count?.adults || 0}명, 소아 ${r.traveler_count?.children || 0}명, 유아 ${r.traveler_count?.infants || 0}명</td>
                                </tr>
                            </table>
                        </div>
                        
                        <!-- 입금 내역 -->
                        <div class="doc-section">
                            <div class="doc-section-title">2. 입금 내역 (매출)</div>
                            <table class="doc-table">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">번호</th>
                                        <th>결제수단</th>
                                        <th>입금일자</th>
                                        <th style="width: 150px;" class="text-end">금액</th>
                                        <th>비고</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${completedBillings.map((b, idx) => {
                                        const typeIcon = b.type === 'cash' ? '💵' : b.type === 'card' ? '💳' : '🎁';
                                        const typeName = b.type === 'cash' ? '현금' : b.type === 'card' ? '카드' : '할인';
                                        return `
                                            <tr>
                                                <td class="text-center">${idx + 1}</td>
                                                <td>${typeIcon} ${typeName}</td>
                                                <td>${b.date ? new Date(b.date).toLocaleDateString('ko-KR') : '-'}</td>
                                                <td class="text-end"><strong>₩${(b.amount || 0).toLocaleString()}</strong></td>
                                                <td>${b.notes || '-'}</td>
                                            </tr>
                                        `;
                                    }).join('')}
                                    <tr style="background-color: #e9ecef;">
                                        <td colspan="3" class="text-end"><strong>입금 총액 (매출액)</strong></td>
                                        <td class="text-end"><strong style="font-size: 1.2em; color: #28a745;">₩${totalReceived.toLocaleString()}</strong></td>
                                        <td></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- 매입 내역 -->
                        <div class="doc-section">
                            <div class="doc-section-title">3. 매입 내역 (원가)</div>
                            <table class="doc-table">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">번호</th>
                                        <th>구성요소</th>
                                        <th>매입처</th>
                                        <th>송금일자</th>
                                        <th style="width: 150px;" class="text-end">매입액</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${components.map((c, idx) => {
                                        const typeIcon = c.component_type === 'flight' ? '✈️' : 
                                                       c.component_type === 'hotel' ? '🏨' : 
                                                       c.component_type === 'tour' ? '🎯' : 
                                                       c.component_type === 'ground' ? '🚗' : '📦';
                                        const typeName = c.component_type === 'flight' ? '항공권' : 
                                                       c.component_type === 'hotel' ? '호텔' : 
                                                       c.component_type === 'tour' ? '투어' : 
                                                       c.component_type === 'ground' ? '지상교통' : '기타';
                                        return `
                                            <tr>
                                                <td class="text-center">${idx + 1}</td>
                                                <td>${typeIcon} ${typeName}</td>
                                                <td>${c.vendor_name}</td>
                                                <td>${c.payment_sent_date ? new Date(c.payment_sent_date).toLocaleDateString('ko-KR') : '-'}</td>
                                                <td class="text-end"><strong>₩${(c.cost_krw || 0).toLocaleString()}</strong></td>
                                            </tr>
                                        `;
                                    }).join('')}
                                    <tr style="background-color: #e9ecef;">
                                        <td colspan="4" class="text-end"><strong>매입 총액 (원가)</strong></td>
                                        <td class="text-end"><strong style="font-size: 1.2em; color: #dc3545;">₩${totalCost.toLocaleString()}</strong></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- 변경이력 (있을 경우에만 표시) -->
                        ${(() => {
                            const allLogs = components.flatMap((c, idx) => 
                                (c.change_logs || []).map(log => ({
                                    ...log,
                                    vendor: c.vendor_name,
                                    component_type: c.component_type
                                }))
                            );
                            if (allLogs.length === 0) return '';
                            const typeLabel = { cost: '금액변경', date: '날짜변경', cancel: '송금취소' };
                            return `
                            <div class="doc-section">
                                <div class="doc-section-title" style="border-left-color: #dc3545;">4. 변경이력</div>
                                <table class="doc-table">
                                    <thead>
                                        <tr>
                                            <th style="width:40px;">번호</th>
                                            <th style="width:80px;">구분</th>
                                            <th>매입처</th>
                                            <th>변경전</th>
                                            <th>변경후</th>
                                            <th>사유</th>
                                            <th style="width:120px;">변경일시</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${allLogs.map((log, i) => `
                                            <tr style="background-color: #fff3cd;">
                                                <td class="text-center">${i + 1}</td>
                                                <td><span style="color:#dc3545;font-weight:bold;">${typeLabel[log.type] || log.type}</span></td>
                                                <td>${log.vendor}</td>
                                                <td>${log.before}</td>
                                                <td>${log.after}</td>
                                                <td>${log.reason}</td>
                                                <td>${new Date(log.changed_at).toLocaleString('ko-KR')}</td>
                                            </tr>
                                        `).join('')}
                                    </tbody>
                                </table>
                            </div>
                            `;
                        })()}

                        <!-- 정산 요약 -->
                        <div class="doc-summary">
                            <div class="doc-summary-title">정산 요약</div>
                            <table class="doc-table">
                                <tr>
                                    <th style="width: 200px;">항목</th>
                                    <th class="text-end">금액</th>
                                    <th style="width: 300px;">비고</th>
                                </tr>
                                <tr>
                                    <td><strong>① 총 입금액 (매출)</strong></td>
                                    <td class="text-end"><strong style="color: #28a745;">₩${totalReceived.toLocaleString()}</strong></td>
                                    <td>고객으로부터 받은 총 금액</td>
                                </tr>
                                <tr>
                                    <td><strong>② 총 매입액 (원가)</strong></td>
                                    <td class="text-end"><strong style="color: #dc3545;">₩${totalCost.toLocaleString()}</strong></td>
                                    <td>매입처에 지급한 총 금액</td>
                                </tr>
                                <tr style="background-color: #fff;">
                                    <td><strong>③ 총 수익 (① - ②)</strong></td>
                                    <td class="text-end"><strong style="color: #007bff; font-size: 1.2em;">₩${profit.toLocaleString()}</strong></td>
                                    <td>매출 - 원가</td>
                                </tr>
                                <tr>
                                    <td><strong>④ 부가가치세 (10%)</strong></td>
                                    <td class="text-end"><strong style="color: #6c757d;">₩${vat.toLocaleString()}</strong></td>
                                    <td>수익의 10% (국세청 신고용)</td>
                                </tr>
                                <tr style="background-color: #d4edda;">
                                    <td><strong>⑤ 순수익 (③ - ④)</strong></td>
                                    <td class="text-end"><strong style="color: #155724; font-size: 1.3em;">₩${netProfit.toLocaleString()}</strong></td>
                                    <td>부가세 제외 실제 수익</td>
                                </tr>
                            </table>
                        </div>
                        
                        <!-- 문서 하단 -->
                        <div class="doc-footer">
                            <p style="margin-bottom: 10px;">위 내용은 사실과 다름없음을 확인합니다.</p>
                            <p><strong>발행일자:</strong> ${new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                        </div>
                        
                    </div>
                `;
                
                document.getElementById('settlementDocument').innerHTML = documentHtml;
                
                const modal = new bootstrap.Modal(document.getElementById('settlementDocumentModal'));
                modal.show();
                
            } catch (error) {
                console.error('정산서 생성 실패:', error);
                alert('정산서를 생성하는 중 오류가 발생했습니다.');
            }
        }
        
        // 정산서 인쇄
        function printSettlement() {
            window.print();
        }

        // ===== 정산현황 탭 =====
        const krw = v => '₩' + Math.round(v).toLocaleString();

        async function loadSettlementStatus() {
            const tbody = document.getElementById('statusTableBody');
            tbody.innerHTML = '<tr><td colspan="14" class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></td></tr>';
            try {
                const res = await fetch('/api/package-settlements/status');
                const d = await res.json();
                if (!d.success) throw new Error(d.message);

                // 요약
                document.getElementById('sum_deposit').textContent = krw(d.summary.total_deposit);
                document.getElementById('sum_receivable').textContent = krw(d.summary.total_receivable);
                document.getElementById('sum_prepaid').textContent = krw(d.summary.total_prepaid);
                document.getElementById('sum_payable').textContent = krw(d.summary.total_payable);

                if (!d.list.length) {
                    tbody.innerHTML = '<tr><td colspan="14" class="text-center py-4 text-muted">데이터가 없습니다.</td></tr>';
                    return;
                }

                tbody.innerHTML = d.list.map(r => {
                    const dep = r.departure_date ? new Date(r.departure_date).toLocaleDateString('ko-KR', {month:'2-digit',day:'2-digit'}) : '-';
                    const depFull = r.departure_date ? new Date(r.departure_date).toLocaleDateString('ko-KR') : '-';
                    const marginColor = r.margin >= 0 ? 'text-success' : 'text-danger';
                    let statusBadge = '';
                    if (r.receivable > 0) statusBadge += '<span class="badge bg-danger me-1">미수금</span>';
                    if (r.deposit > 0) statusBadge += '<span class="badge bg-success me-1">수탁</span>';
                    if (r.payable > 0) statusBadge += '<span class="badge bg-warning text-dark me-1">미지급</span>';
                    if (r.prepaid > 0) statusBadge += '<span class="badge bg-primary me-1">선급</span>';
                    if (!statusBadge) statusBadge = '<span class="badge bg-secondary">정산완료</span>';
                    return `<tr class="${r.departed ? '' : 'table-light'}">
                        <td title="${depFull}">${dep}</td>
                        <td><small>${r.reservation_number}</small></td>
                        <td><small>${r.platform_name}</small></td>
                        <td>${r.customer_name}</td>
                        <td class="text-end">${krw(r.total_selling)}</td>
                        <td class="text-end">${krw(r.received_amount)}</td>
                        <td class="text-end text-success fw-bold">${r.deposit > 0 ? krw(r.deposit) : '-'}</td>
                        <td class="text-end text-danger fw-bold">${r.receivable > 0 ? krw(r.receivable) : '-'}</td>
                        <td class="text-end">${krw(r.total_cost)}</td>
                        <td class="text-end">${krw(r.sent_amount)}</td>
                        <td class="text-end text-primary fw-bold">${r.prepaid > 0 ? krw(r.prepaid) : '-'}</td>
                        <td class="text-end text-warning fw-bold">${r.payable > 0 ? krw(r.payable) : '-'}</td>
                        <td class="text-end fw-bold ${marginColor}">${krw(r.margin)}</td>
                        <td>${statusBadge}</td>
                    </tr>`;
                }).join('');
            } catch (e) {
                tbody.innerHTML = `<tr><td colspan="14" class="text-center py-4 text-danger">로드 실패: ${e.message}</td></tr>`;
            }
        }
        
        // Enter 키 검색 이벤트
        ['filter_search', 'filter_vendor'].forEach(id => {
            document.getElementById(id)?.addEventListener('keydown', e => {
                if (e.key === 'Enter') filterAndRender();
            });
        });

        // 페이지 로드 시 실행
        window.addEventListener('load', () => {
            loadSettlements();
        });
    </script>
</body>
</html>
