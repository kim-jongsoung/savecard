<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>통합정산회계 - 괌세이브카드 관리자</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: #f8f9fa; }
        .erp-badge-activity { background: #c8e6c9; color: #2e7d32; font-size:.75rem; }
        .erp-badge-hotel    { background: #ffe0b2; color: #e65100; font-size:.75rem; }
        .erp-badge-package  { background: #f3e5f5; color: #6a1b9a; font-size:.75rem; }
        .status-cell { min-width: 120px; }
        .in-status-sutak    { color: #1565c0; font-weight:600; }
        .in-status-completed { color: #2e7d32; font-weight:600; }
        .in-status-receivable { color: #c62828; font-weight:600; }
        .out-status-prepaid   { color: #1565c0; font-weight:600; }
        .out-status-completed { color: #2e7d32; font-weight:600; }
        .out-status-payable   { color: #e65100; font-weight:600; }
        .tbl-departed td { background: #fff; }
        .tbl-notdep td  { background: #f0f7ff; }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { currentPage: 'integrated-settlement', adminUsername: adminUsername || '관리자' }) %>

    <div class="container-fluid mt-3">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h4 class="mb-0"><i class="fas fa-chart-pie me-2"></i>통합정산회계</h4>
            <button class="btn btn-sm btn-outline-primary" onclick="loadAll()"><i class="fas fa-sync-alt me-1"></i>새로고침</button>
        </div>

        <!-- 요약 카드 -->
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="card border-primary h-100">
                    <div class="card-body py-2 px-3">
                        <div class="small text-muted">수탁액 <span class="badge bg-primary ms-1">출발전 입금</span></div>
                        <div class="fw-bold fs-5 text-primary" id="sum_deposit">-</div>
                        <div class="small text-muted mt-1">즐길 <span id="dep_activity">-</span> / 호텔 <span id="dep_hotel">-</span> / 패키지 <span id="dep_package">-</span></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-danger h-100">
                    <div class="card-body py-2 px-3">
                        <div class="small text-muted">미수금 <span class="badge bg-danger ms-1">출발후 미입금</span></div>
                        <div class="fw-bold fs-5 text-danger" id="sum_receivable">-</div>
                        <div class="small text-muted mt-1">즐길 <span id="rec_activity">-</span> / 호텔 <span id="rec_hotel">-</span> / 패키지 <span id="rec_package">-</span></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-warning h-100">
                    <div class="card-body py-2 px-3">
                        <div class="small text-muted">선급금 <span class="badge bg-warning text-dark ms-1">출발전 송금</span></div>
                        <div class="fw-bold fs-5 text-warning" id="sum_prepaid">-</div>
                        <div class="small text-muted mt-1">호텔 <span id="pre_hotel">-</span> / 패키지 <span id="pre_package">-</span></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-danger h-100" style="border-color:#e65100!important">
                    <div class="card-body py-2 px-3">
                        <div class="small text-muted">미지급금 <span class="badge ms-1" style="background:#e65100">출발후 미송금</span></div>
                        <div class="fw-bold fs-5" style="color:#e65100" id="sum_payable">-</div>
                        <div class="small text-muted mt-1">호텔 <span id="pay_hotel">-</span> / 패키지 <span id="pay_package">-</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 필터 -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="d-flex gap-2 flex-wrap align-items-end">
                    <div>
                        <label class="form-label small mb-1">ERP 구분</label>
                        <select class="form-select form-select-sm" id="filterErp" style="width:120px">
                            <option value="">전체</option>
                            <option value="activity">즐길거리</option>
                            <option value="hotel">호텔</option>
                            <option value="package">패키지</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label small mb-1">입금상태</label>
                        <select class="form-select form-select-sm" id="filterInStatus" style="width:120px">
                            <option value="">전체</option>
                            <option value="sutak">수탁액</option>
                            <option value="in_completed">입금완료</option>
                            <option value="receivable">미수금</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label small mb-1">송금상태</label>
                        <select class="form-select form-select-sm" id="filterOutStatus" style="width:120px">
                            <option value="">전체</option>
                            <option value="prepaid">선급금</option>
                            <option value="out_completed">송금완료</option>
                            <option value="payable">미지급금</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label small mb-1">출발일 시작</label>
                        <input type="date" class="form-control form-control-sm" id="filterStart" style="width:140px">
                    </div>
                    <div>
                        <label class="form-label small mb-1">출발일 종료</label>
                        <input type="date" class="form-control form-control-sm" id="filterEnd" style="width:140px">
                    </div>
                    <div>
                        <label class="form-label small mb-1">검색</label>
                        <input type="text" class="form-control form-control-sm" id="filterSearch" placeholder="예약번호, 고객명" style="width:160px">
                    </div>
                    <button class="btn btn-primary btn-sm" onclick="applyFilter()"><i class="fas fa-search me-1"></i>검색</button>
                    <button class="btn btn-outline-secondary btn-sm" onclick="resetFilter()"><i class="fas fa-undo"></i></button>
                    <span class="ms-auto small text-muted" id="rowCount"></span>
                </div>
            </div>
        </div>

        <!-- 테이블 -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size:.82rem">
                <thead class="table-dark">
                    <tr>
                        <th>ERP</th>
                        <th>출발일</th>
                        <th>예약번호</th>
                        <th>채널</th>
                        <th>고객명</th>
                        <th class="text-end">입금액</th>
                        <th class="text-center status-cell">입금상태</th>
                        <th class="text-end">매입금액</th>
                        <th class="text-center status-cell">송금상태</th>
                        <th class="text-end">손익</th>
                    </tr>
                </thead>
                <tbody id="mainTableBody">
                    <tr><td colspan="10" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const krw = v => v ? '₩' + Math.round(v).toLocaleString() : '-';
        let allData = [];
        const now = new Date();

        // 입금상태 동적 계산: payment_date + departure_date 기준
        // payment_date 있고 출발전 → 수탁액
        // payment_date 있고 출발후 → 입금완료
        // payment_date 없고 출발후 → 미수금
        // payment_date 없고 출발전 → (없음)
        function calcInStatus(r) {
            const dep = r.departure_date ? new Date(r.departure_date) : null;
            const departed = dep ? dep < now : false;
            const hasPay = !!r.payment_date;
            const amt = r.received_amount || 0;
            if (hasPay && !departed)  return { key: 'sutak',        label: '수탁액',  cls: 'in-status-sutak',     amt };
            if (hasPay && departed)   return { key: 'in_completed', label: '입금완료', cls: 'in-status-completed', amt };
            if (!hasPay && departed && amt > 0) return { key: 'receivable',   label: '미수금',  cls: 'in-status-receivable', amt };
            return null;
        }

        // 송금상태 동적 계산: transfer_date + departure_date 기준
        // transfer_date 있고 출발전 → 선급금
        // transfer_date 있고 출발후 → 송금완료
        // transfer_date 없고 출발후 → 미지급금
        // transfer_date 없고 출발전 → (없음)
        function calcOutStatus(r) {
            const dep = r.departure_date ? new Date(r.departure_date) : null;
            const departed = dep ? dep < now : false;
            const hasTrans = !!r.transfer_date;
            const amt = r.sent_amount || r.total_cost || 0;
            if (hasTrans && !departed)  return { key: 'prepaid',       label: '선급금',   cls: 'out-status-prepaid',   amt };
            if (hasTrans && departed)   return { key: 'out_completed',  label: '송금완료',  cls: 'out-status-completed', amt };
            if (!hasTrans && departed && amt > 0) return { key: 'payable', label: '미지급금', cls: 'out-status-payable', amt };
            return null;
        }

        async function loadAll() {
            document.getElementById('mainTableBody').innerHTML =
                '<tr><td colspan="10" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>';

            const [r1, r2] = await Promise.all([
                fetch('/api/integrated-settlement/status').then(r => r.json()),
                fetch('/api/package-settlements/status').then(r => r.json())
            ]);

            const pkgList = (r2.success ? r2.list : []).map(r => ({ ...r, erp: 'package', erp_label: '패키지' }));
            allData = [...(r1.success ? r1.list : []), ...pkgList]
                .sort((a, b) => {
                    if (!a.departure_date) return 1;
                    if (!b.departure_date) return -1;
                    return new Date(b.departure_date) - new Date(a.departure_date);
                });

            // 요약: 실시간 calcInStatus/calcOutStatus 기준으로 계산
            const sumByKey = (key, erpFilter) => allData
                .filter(r => !erpFilter || r.erp === erpFilter)
                .reduce((s, r) => {
                    const inS  = calcInStatus(r);
                    const outS = calcOutStatus(r);
                    if (key === 'deposit'    && inS?.key  === 'sutak')        return s + (inS.amt  || 0);
                    if (key === 'receivable' && inS?.key  === 'receivable')   return s + (inS.amt  || 0);
                    if (key === 'prepaid'    && outS?.key === 'prepaid')      return s + (outS.amt || 0);
                    if (key === 'payable'    && outS?.key === 'payable')      return s + (outS.amt || 0);
                    return s;
                }, 0);

            document.getElementById('sum_deposit').textContent    = krw(sumByKey('deposit'));
            document.getElementById('sum_receivable').textContent = krw(sumByKey('receivable'));
            document.getElementById('sum_prepaid').textContent    = krw(sumByKey('prepaid'));
            document.getElementById('sum_payable').textContent    = krw(sumByKey('payable'));

            document.getElementById('dep_activity').textContent = krw(sumByKey('deposit',    'activity'));
            document.getElementById('dep_hotel').textContent    = krw(sumByKey('deposit',    'hotel'));
            document.getElementById('dep_package').textContent  = krw(sumByKey('deposit',    'package'));
            document.getElementById('rec_activity').textContent = krw(sumByKey('receivable', 'activity'));
            document.getElementById('rec_hotel').textContent    = krw(sumByKey('receivable', 'hotel'));
            document.getElementById('rec_package').textContent  = krw(sumByKey('receivable', 'package'));
            document.getElementById('pre_hotel').textContent    = krw(sumByKey('prepaid',    'hotel'));
            document.getElementById('pre_package').textContent  = krw(sumByKey('prepaid',    'package'));
            document.getElementById('pay_hotel').textContent    = krw(sumByKey('payable',    'hotel'));
            document.getElementById('pay_package').textContent  = krw(sumByKey('payable',    'package'));

            renderTable(allData);
        }

        function applyFilter() {
            const erp       = document.getElementById('filterErp').value;
            const inStatus  = document.getElementById('filterInStatus').value;
            const outStatus = document.getElementById('filterOutStatus').value;
            const start     = document.getElementById('filterStart').value;
            const end       = document.getElementById('filterEnd').value;
            const search    = document.getElementById('filterSearch').value.toLowerCase();

            const filtered = allData.filter(r => {
                if (erp && r.erp !== erp) return false;
                if (inStatus) {
                    const s = calcInStatus(r);
                    if (!s || s.key !== inStatus) return false;
                }
                if (outStatus) {
                    const s = calcOutStatus(r);
                    if (!s || s.key !== outStatus) return false;
                }
                if (start && r.departure_date && new Date(r.departure_date) < new Date(start)) return false;
                if (end   && r.departure_date && new Date(r.departure_date) > new Date(end + 'T23:59:59')) return false;
                if (search && !(
                    (r.reservation_number || '').toLowerCase().includes(search) ||
                    (r.customer_name || '').toLowerCase().includes(search) ||
                    (r.platform_name || '').toLowerCase().includes(search)
                )) return false;
                return true;
            });
            renderTable(filtered);
        }

        function resetFilter() {
            ['filterErp','filterInStatus','filterOutStatus','filterStart','filterEnd','filterSearch']
                .forEach(id => { document.getElementById(id).value = ''; });
            renderTable(allData);
        }

        const fmtDate = v => {
            if (!v) return null;
            const d = new Date(v);
            if (isNaN(d)) return null;
            return `${d.getFullYear().toString().slice(-2)}.${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`;
        };

        function renderTable(list) {
            document.getElementById('rowCount').textContent = `총 ${list.length}건`;
            const tbody = document.getElementById('mainTableBody');
            if (!list.length) {
                tbody.innerHTML = '<tr><td colspan="10" class="text-center py-4 text-muted">데이터가 없습니다.</td></tr>';
                return;
            }
            tbody.innerHTML = list.map(r => {
                const dep = r.departure_date ? new Date(r.departure_date) : null;
                const departed = dep ? dep < now : false;
                const depStr = fmtDate(r.departure_date) || '-';
                const erpBadge = `<span class="badge erp-badge-${r.erp} px-2 py-1">${r.erp_label}</span>`;

                const inS  = calcInStatus(r);
                const outS = calcOutStatus(r);

                // 입금상태 셀
                let inCell = '<span class="text-muted">-</span>';
                if (inS) {
                    const dtStr = fmtDate(r.payment_date);
                    inCell = `<div class="${inS.cls}">${inS.label}</div>` +
                             `<div class="small fw-bold">${krw(inS.amt)}</div>` +
                             (dtStr ? `<div class="small text-muted">${dtStr}</div>` : '');
                }

                // 송금상태 셀
                let outCell = '<span class="text-muted">-</span>';
                if (outS) {
                    const dtStr = fmtDate(r.transfer_date);
                    outCell = `<div class="${outS.cls}">${outS.label}</div>` +
                              `<div class="small fw-bold">${krw(outS.amt)}</div>` +
                              (dtStr ? `<div class="small text-muted">${dtStr}</div>` : '');
                }

                // 손익
                const inAmt  = inS  ? (inS.amt  || 0) : 0;
                const outAmt = outS ? (outS.amt || 0) : 0;
                const margin = (r.received_amount || 0) - (r.sent_amount || r.total_cost || 0);
                const marginColor = margin >= 0 ? 'text-success' : 'text-danger';

                const trCls = departed ? 'tbl-departed' : 'tbl-notdep';

                return `<tr class="${trCls}">
                    <td>${erpBadge}</td>
                    <td class="text-nowrap">${depStr}</td>
                    <td><small class="text-muted">${r.reservation_number || '-'}</small></td>
                    <td><small>${r.platform_name || '-'}</small></td>
                    <td>${r.customer_name || '-'}${r.detail_label ? `<br><small class="text-muted">${r.detail_label}</small>` : ''}</td>
                    <td class="text-end">${r.received_amount > 0 ? krw(r.received_amount) : '-'}</td>
                    <td class="text-center status-cell">${inCell}</td>
                    <td class="text-end">${(r.sent_amount || r.total_cost) > 0 ? krw(r.sent_amount || r.total_cost) : '-'}</td>
                    <td class="text-center status-cell">${outCell}</td>
                    <td class="text-end fw-bold ${marginColor}">${krw(margin)}</td>
                </tr>`;
            }).join('');
        }

        document.getElementById('filterSearch').addEventListener('keydown', e => {
            if (e.key === 'Enter') applyFilter();
        });

        window.addEventListener('load', loadAll);
    </script>
</body>
</html>
