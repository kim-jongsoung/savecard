<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>통합정산회계 - 괌세이브카드 관리자</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: #f8f9fa; }
        .erp-badge-activity { background: #c8e6c9; color: #2e7d32; }
        .erp-badge-hotel    { background: #ffe0b2; color: #e65100; }
        .erp-badge-package  { background: #f3e5f5; color: #6a1b9a; }
    </style>
</head>
<body>
    <%- include('../partials/navbar', { currentPage: 'integrated-settlement', adminUsername: adminUsername || '관리자' }) %>

    <div class="container-fluid mt-3">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h4 class="mb-0"><i class="fas fa-chart-pie me-2"></i>통합정산회계</h4>
            <button class="btn btn-sm btn-outline-primary" onclick="loadAll()"><i class="fas fa-sync-alt me-1"></i>새로고침</button>
        </div>

        <!-- 요약 카드 -->
        <div class="row g-3 mb-3">
            <div class="col-6 col-md-3">
                <div class="card border-success h-100">
                    <div class="card-body py-2 px-3">
                        <div class="small text-muted">수탁액 <span class="badge bg-success ms-1">출발전 입금</span></div>
                        <div class="fw-bold fs-5 text-success" id="sum_deposit">-</div>
                        <div class="small text-muted mt-1">즐길거리 <span id="dep_activity">-</span> / 호텔 <span id="dep_hotel">-</span> / 패키지 <span id="dep_package">-</span></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-danger h-100">
                    <div class="card-body py-2 px-3">
                        <div class="small text-muted">미수금 <span class="badge bg-danger ms-1">출발후 미입금</span></div>
                        <div class="fw-bold fs-5 text-danger" id="sum_receivable">-</div>
                        <div class="small text-muted mt-1">즐길거리 <span id="rec_activity">-</span> / 호텔 <span id="rec_hotel">-</span> / 패키지 <span id="rec_package">-</span></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-primary h-100">
                    <div class="card-body py-2 px-3">
                        <div class="small text-muted">선급금 <span class="badge bg-primary ms-1">출발전 송금</span></div>
                        <div class="fw-bold fs-5 text-primary" id="sum_prepaid">-</div>
                        <div class="small text-muted mt-1">호텔 <span id="pre_hotel">-</span> / 패키지 <span id="pre_package">-</span></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-warning h-100">
                    <div class="card-body py-2 px-3">
                        <div class="small text-muted">미지급금 <span class="badge bg-warning text-dark ms-1">출발후 미송금</span></div>
                        <div class="fw-bold fs-5 text-warning" id="sum_payable">-</div>
                        <div class="small text-muted mt-1">호텔 <span id="pay_hotel">-</span> / 패키지 <span id="pay_package">-</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 필터 -->
        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="d-flex gap-2 flex-wrap align-items-end">
                    <div>
                        <label class="form-label small mb-1">ERP 구분</label>
                        <select class="form-select form-select-sm" id="filterErp" style="width:130px">
                            <option value="">전체</option>
                            <option value="activity">즐길거리</option>
                            <option value="hotel">호텔</option>
                            <option value="package">패키지</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label small mb-1">상태</label>
                        <select class="form-select form-select-sm" id="filterStatus" style="width:130px">
                            <option value="">전체</option>
                            <option value="receivable">미수금</option>
                            <option value="deposit">수탁액</option>
                            <option value="payable">미지급금</option>
                            <option value="prepaid">선급금</option>
                            <option value="settled">정산완료</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label small mb-1">출발일 시작</label>
                        <input type="date" class="form-control form-control-sm" id="filterStart" style="width:140px">
                    </div>
                    <div>
                        <label class="form-label small mb-1">출발일 종료</label>
                        <input type="date" class="form-control form-control-sm" id="filterEnd" style="width:140px">
                    </div>
                    <div>
                        <label class="form-label small mb-1">검색</label>
                        <input type="text" class="form-control form-control-sm" id="filterSearch" placeholder="예약번호, 고객명" style="width:160px">
                    </div>
                    <button class="btn btn-primary btn-sm" onclick="applyFilter()"><i class="fas fa-search me-1"></i>검색</button>
                    <button class="btn btn-outline-secondary btn-sm" onclick="resetFilter()"><i class="fas fa-undo"></i></button>
                    <span class="ms-auto small text-muted" id="rowCount"></span>
                </div>
            </div>
        </div>

        <!-- 테이블 -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size:.82rem">
                <thead class="table-dark">
                    <tr>
                        <th>ERP</th>
                        <th>출발일</th>
                        <th>예약번호</th>
                        <th>채널</th>
                        <th>고객명</th>
                        <th class="text-end">판매금액</th>
                        <th class="text-end">입금액</th>
                        <th class="text-end text-success">수탁액</th>
                        <th class="text-end text-danger">미수금</th>
                        <th class="text-end">매입총액</th>
                        <th class="text-end">송금액</th>
                        <th class="text-end text-primary">선급금</th>
                        <th class="text-end text-warning">미지급금</th>
                        <th class="text-end">손익</th>
                        <th>상태</th>
                    </tr>
                </thead>
                <tbody id="mainTableBody">
                    <tr><td colspan="15" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const krw = v => '₩' + Math.round(v || 0).toLocaleString();
        let allData = [];

        async function loadAll() {
            document.getElementById('mainTableBody').innerHTML =
                '<tr><td colspan="15" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>';

            // 즐길거리+호텔
            const r1 = await fetch('/api/integrated-settlement/status').then(r => r.json());
            // 패키지
            const r2 = await fetch('/api/package-settlements/status').then(r => r.json());

            const pkgList = (r2.success ? r2.list : []).map(r => ({ ...r, erp: 'package', erp_label: '패키지' }));
            allData = [...(r1.success ? r1.list : []), ...pkgList]
                .sort((a, b) => {
                    if (!a.departure_date) return 1;
                    if (!b.departure_date) return -1;
                    return new Date(b.departure_date) - new Date(a.departure_date);
                });

            // 요약 계산
            const sum = (key, erpFilter) => allData.filter(r => !erpFilter || r.erp === erpFilter).reduce((s, r) => s + (r[key] || 0), 0);

            document.getElementById('sum_deposit').textContent    = krw(sum('deposit'));
            document.getElementById('sum_receivable').textContent = krw(sum('receivable'));
            document.getElementById('sum_prepaid').textContent    = krw(sum('prepaid'));
            document.getElementById('sum_payable').textContent    = krw(sum('payable'));

            document.getElementById('dep_activity').textContent = krw(sum('deposit', 'activity'));
            document.getElementById('dep_hotel').textContent    = krw(sum('deposit', 'hotel'));
            document.getElementById('dep_package').textContent  = krw(sum('deposit', 'package'));
            document.getElementById('rec_activity').textContent = krw(sum('receivable', 'activity'));
            document.getElementById('rec_hotel').textContent    = krw(sum('receivable', 'hotel'));
            document.getElementById('rec_package').textContent  = krw(sum('receivable', 'package'));
            document.getElementById('pre_hotel').textContent    = krw(sum('prepaid', 'hotel'));
            document.getElementById('pre_package').textContent  = krw(sum('prepaid', 'package'));
            document.getElementById('pay_hotel').textContent    = krw(sum('payable', 'hotel'));
            document.getElementById('pay_package').textContent  = krw(sum('payable', 'package'));

            renderTable(allData);
        }

        function applyFilter() {
            const erp    = document.getElementById('filterErp').value;
            const status = document.getElementById('filterStatus').value;
            const start  = document.getElementById('filterStart').value;
            const end    = document.getElementById('filterEnd').value;
            const search = document.getElementById('filterSearch').value.toLowerCase();

            let filtered = allData.filter(r => {
                if (erp && r.erp !== erp) return false;
                if (status === 'receivable' && !(r.receivable > 0)) return false;
                if (status === 'deposit'    && !(r.deposit > 0)) return false;
                if (status === 'payable'    && !(r.payable > 0)) return false;
                if (status === 'prepaid'    && !(r.prepaid > 0)) return false;
                if (status === 'settled' && (r.receivable > 0 || r.deposit > 0 || r.payable > 0 || r.prepaid > 0)) return false;
                if (start && r.departure_date && new Date(r.departure_date) < new Date(start)) return false;
                if (end   && r.departure_date && new Date(r.departure_date) > new Date(end + 'T23:59:59')) return false;
                if (search && !(
                    (r.reservation_number || '').toLowerCase().includes(search) ||
                    (r.customer_name || '').toLowerCase().includes(search) ||
                    (r.platform_name || '').toLowerCase().includes(search)
                )) return false;
                return true;
            });
            renderTable(filtered);
        }

        function resetFilter() {
            ['filterErp','filterStatus','filterStart','filterEnd','filterSearch'].forEach(id => {
                const el = document.getElementById(id);
                el.value = '';
            });
            renderTable(allData);
        }

        function renderTable(list) {
            document.getElementById('rowCount').textContent = `총 ${list.length}건`;
            const tbody = document.getElementById('mainTableBody');
            if (!list.length) {
                tbody.innerHTML = '<tr><td colspan="15" class="text-center py-4 text-muted">데이터가 없습니다.</td></tr>';
                return;
            }
            tbody.innerHTML = list.map(r => {
                const dep = r.departure_date
                    ? new Date(r.departure_date).toLocaleDateString('ko-KR', {year:'2-digit',month:'2-digit',day:'2-digit'})
                    : '-';
                const erpBadge = `<span class="badge erp-badge-${r.erp}">${r.erp_label}</span>`;
                const marginColor = (r.margin || 0) >= 0 ? 'text-success' : 'text-danger';
                let statusBadge = '';
                if (r.receivable > 0) statusBadge += '<span class="badge bg-danger me-1">미수금</span>';
                if (r.deposit > 0)    statusBadge += '<span class="badge bg-success me-1">수탁</span>';
                if (r.payable > 0)    statusBadge += '<span class="badge bg-warning text-dark me-1">미지급</span>';
                if (r.prepaid > 0)    statusBadge += '<span class="badge bg-primary me-1">선급</span>';
                if (!statusBadge)     statusBadge  = '<span class="badge bg-secondary">정산완료</span>';
                return `<tr class="${r.departed ? '' : 'table-light'}">
                    <td>${erpBadge}</td>
                    <td>${dep}</td>
                    <td><small>${r.reservation_number || '-'}</small></td>
                    <td><small>${r.platform_name || '-'}</small></td>
                    <td>${r.customer_name || '-'}</td>
                    <td class="text-end">${krw(r.total_selling)}</td>
                    <td class="text-end">${krw(r.received_amount)}</td>
                    <td class="text-end text-success fw-bold">${r.deposit > 0 ? krw(r.deposit) : '-'}</td>
                    <td class="text-end text-danger fw-bold">${r.receivable > 0 ? krw(r.receivable) : '-'}</td>
                    <td class="text-end">${r.total_cost > 0 ? krw(r.total_cost) : '-'}</td>
                    <td class="text-end">${r.sent_amount > 0 ? krw(r.sent_amount) : '-'}</td>
                    <td class="text-end text-primary fw-bold">${r.prepaid > 0 ? krw(r.prepaid) : '-'}</td>
                    <td class="text-end text-warning fw-bold">${r.payable > 0 ? krw(r.payable) : '-'}</td>
                    <td class="text-end fw-bold ${marginColor}">${krw(r.margin)}</td>
                    <td>${statusBadge}</td>
                </tr>`;
            }).join('');
        }

        document.getElementById('filterSearch').addEventListener('keydown', e => {
            if (e.key === 'Enter') applyFilter();
        });

        window.addEventListener('load', loadAll);
    </script>
</body>
</html>
